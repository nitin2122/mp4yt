---
// SupportedSites — infinite marquee logo strip
---

<section id="platforms" class="platforms-band" aria-labelledby="platforms-label">
  <div class="page-container platforms-header">
    <span id="platforms-label" class="eyebrow">Supported platforms</span>
    <p class="body-sm platforms-sub" style="color: var(--color-mute);">
      Powered by Cobalt — works with 1000+ video sites
    </p>
  </div>

  <!-- Marquee strip -->
  <div class="marquee-wrapper" aria-hidden="true">
    <div class="marquee-fade-left"></div>
    <div class="marquee-fade-right"></div>
    <div class="marquee-outer">
      <div class="marquee-track">
        <!-- Platform logos (inline SVGs for speed) -->

        <!-- Instagram -->
        <div class="platform-chip">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="Instagram">
            <rect width="16" height="16" rx="4" fill="url(#ig-grad)"/>
            <circle cx="8" cy="8" r="3" stroke="white" stroke-width="1.3"/>
            <circle cx="11.5" cy="4.5" r="0.8" fill="white"/>
            <defs>
              <radialGradient id="ig-grad" cx="30%" cy="100%" r="120%">
                <stop offset="0%" stop-color="#ffd600"/>
                <stop offset="50%" stop-color="#ff6530"/>
                <stop offset="100%" stop-color="#c13584"/>
              </radialGradient>
            </defs>
          </svg>
          <span>Instagram</span>
        </div>

        <!-- TikTok -->
        <div class="platform-chip">
          <svg width="14" height="16" viewBox="0 0 14 16" fill="none" aria-label="TikTok">
            <rect width="14" height="16" rx="3" fill="#010101"/>
            <path d="M9.5 1.5c.2 1.5 1 2.3 2 2.5v2c-1.1-.1-1.8-.5-2.5-1.2V9.5a3 3 0 1 1-2-2.8V9a1 1 0 1 0 1 1V1.5h1.5z" fill="white"/>
          </svg>
          <span>TikTok</span>
        </div>

        <!-- Twitter/X -->

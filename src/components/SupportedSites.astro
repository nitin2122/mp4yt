            <rect width="16" height="16" rx="3" fill="#000"/>
            <path d="M9.2 7.1L12.9 3h-.9L8.8 6.5 6.3 3H3.5l3.9 5.6L3.5 13h.9l3.4-3.9 2.7 3.9h2.8L9.2 7.1zm-1.2 1.4l-.4-.5-3-4.3h1.3l2.4 3.5.4.5 3.1 4.4h-1.3l-2.5-3.6z" fill="white"/>
          </svg>
          <span>Twitter/X</span>
        </div>

        <!-- Facebook -->
        <div class="platform-chip">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="Facebook">
            <rect width="16" height="16" rx="3" fill="#1877F2"/>
            <path d="M10.5 8H9v5.5H7V8H5.5V6H7V4.8C7 3.3 7.8 2.5 9.2 2.5l1.3.1v2H9.8c-.5 0-.8.2-.8.8V6H10.5L10.5 8z" fill="white"/>
          </svg>

            <circle cx="8" cy="9" r="3.5" stroke="white" stroke-width="1.2"/>
            <circle cx="5.5" cy="8" r="0.7" fill="white"/>
            <circle cx="10.5" cy="8" r="0.7" fill="white"/>
            <path d="M6 10.5c.6.5 1.6.7 2 0" stroke="white" stroke-width="0.8" stroke-linecap="round"/>
          </svg>
          <span>Reddit</span>
        </div>

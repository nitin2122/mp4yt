        <div class="platform-chip platform-more">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="4" cy="8" r="1.5" fill="var(--color-mute)"/>
            <circle cx="8" cy="8" r="1.5" fill="var(--color-mute)"/>
            <circle cx="12" cy="8" r="1.5" fill="var(--color-mute)"/>
          </svg>
          <span>1000+ more</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .platforms-band {
    background-color: var(--color-canvas);
    padding: var(--sp-4xl) 0;
    border-top: var(--border);
    border-bottom: var(--border);
    overflow: hidden;
  }

  .platforms-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-xs);
    text-align: center;
    margin-bottom: var(--sp-xl);
  }

  .platforms-sub {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Marquee container */
  .marquee-wrapper {
    position: relative;
    overflow: hidden;
  }

  .marquee-fade-left,
  .marquee-fade-right {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }

  .marquee-fade-left {
    left: 0;
    background: linear-gradient(to right, var(--color-canvas), transparent);
  }

  .marquee-fade-right {
    right: 0;
    background: linear-gradient(to left, var(--color-canvas), transparent);
  }

  .marquee-outer {
    overflow: hidden;
    padding: var(--sp-xs) 0;
  }

  .marquee-track {
    display: flex;
    gap: var(--sp-xs);
    width: max-content;
    animation: marquee 40s linear infinite;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  /* Platform chips — Brutalist rectangular */
  .platform-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-xs);
    background-color: var(--color-canvas);
    border: var(--border);
    border-radius: 0px;
    padding: var(--sp-xs) var(--sp-md);
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink);
    flex-shrink: 0;
    transition: all 0.1s ease;
  }

  .platform-chip:hover {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  .platform-more {
    color: var(--color-body);
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }

  @media (max-width: 768px) {
    .marquee-fade-left,
    .marquee-fade-right {
      width: 30px;
    }
    .platforms-band {
      padding: var(--sp-xl) 0;
    }
    .platform-chip {
      font-size: 11px;
      padding: var(--sp-xs) var(--sp-sm);
    }
    .marquee-track {
      animation-duration: 45s;
    }
  }

  @media (max-width: 480px) {
    .marquee-fade-left,
    .marquee-fade-right {
      width: 20px;
    }
    .platform-chip {
      font-size: 10px;
      padding: 5px 8px;
    }
  }
</style>

            <rect width="16" height="16" rx="3" fill="#1AB7EA"/>
            <path d="M13 5.5c-.1 1.8-1.3 4.3-3.8 7.4C6.6 16 4.5 16 3.7 14.7c-.5-.9-1.3-3-1.7-5 0 0-.3-1 .5-1 .7 0 1.2 1 1.2 1l.5 1.5C4.5 12.9 5.5 13 6 12.5c.8-.7 1.5-2 1.5-2L7 6C6.8 4 4.8 4.3 4.8 4.3V3.7c1.2-.5 2.8-.7 3.5-.7C11 3 13.2 3.5 13 5.5z" fill="white"/>
          </svg>
          <span>Vimeo</span>
        </div>
        <div class="platform-chip">
          <svg width="14" height="16" viewBox="0 0 14 16" fill="none" aria-hidden="true">
            <rect width="14" height="16" rx="3" fill="#9146FF"/>
            <path d="M2.5 1L1 3v10h3.5v2L6 13.5H8.5l2-2V1H2.5z" stroke="white" stroke-width="1.2"/>
            <path d="M6.5 5v3.5M9.5 5v3.5" stroke="white" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <span>Twitch</span>
        </div>
        <div class="platform-chip">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect width="16" height="16" rx="3" fill="#003BD8"/>
            <circle cx="8" cy="8" r="3" stroke="white" stroke-width="1.3"/>
            <path d="M6.5 6.5L10 8 6.5 9.5V6.5z" fill="white"/>
          </svg>
          <span>Dailymotion</span>
        </div>
        <div class="platform-chip">
          <svg width="22" height="12" viewBox="0 0 22 12" fill="none" aria-hidden="true">
            <rect width="22" height="12" rx="3" fill="#FF5500"/>

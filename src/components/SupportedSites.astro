            <rect width="16" height="16" rx="3" fill="#0A66C2"/>
            <path d="M3.5 6H5.5v7H3.5V6zM4.5 5c-.6 0-1-.5-1-1s.4-1 1-1 1 .5 1 1-.4 1-1 1zM6.5 6h2v1c.3-.5 1-1 2-1 2 0 2.5 1.3 2.5 3v4H11V9.5c0-1-.4-1.5-1.2-1.5-.9 0-1.3.6-1.3 1.5V13H6.5V6z" fill="white"/>
          </svg>
          <span>LinkedIn</span>
        </div>

        <!-- And many more badge -->
        <div class="platform-chip platform-more">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="4" cy="8" r="1.5" fill="var(--color-mute)"/>
            <circle cx="8" cy="8" r="1.5" fill="var(--color-mute)"/>
            <circle cx="12" cy="8" r="1.5" fill="var(--color-mute)"/>
          </svg>
          <span>1000+ more</span>
        </div>

        <!-- Duplicate for seamless loop -->
        <div class="platform-chip">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect width="16" height="16" rx="4" fill="url(#ig-grad2)"/>
            <circle cx="8" cy="8" r="3" stroke="white" stroke-width="1.3"/>
            <circle cx="11.5" cy="4.5" r="0.8" fill="white"/>
            <defs>
              <radialGradient id="ig-grad2" cx="30%" cy="100%" r="120%">

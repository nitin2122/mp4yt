---
// FAQ Component — Highly SEO-optimized reusable component.
// Automatically renders standard FAQs for the main page or custom ones if passed as props.

interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  faqs?: FAQItem[];
}

const defaultFaqs: FAQItem[] = [
  {
    q: "Is downloading MP4 files from YouTube legal?",
    a: "Downloading MP4 files from YouTube violates YouTube's Terms of Service, which state that users should not download content unless a download link is provided. However, downloading video content for personal, private, and non-commercial use, or under fair use principles, is generally considered a legal gray area. As long as you do not distribute, sell, or monetize the downloaded files, it is highly unlikely to cause legal issues. Always respect creators' copyrights."
  },
  {
    q: "How to download YouTube videos to MP4 for free?",
    a: "To download YouTube videos to MP4 for free, copy the video URL from YouTube's address bar or share sheet. Go to mp4yt.com, paste the link into our input field, and click \"Extract\". Once the direct streams are ready, choose your preferred MP4 resolution (from 360p up to 4K Ultra HD) and click the download button to save the file."
  },
  {
    q: "Is using an online YouTube video downloader safe?",
    a: "Yes, mp4yt is completely safe. Unlike desktop software or browser extensions that might bundle malware or unwanted ads, our tool is 100% web-based. We do not require any installation, account creation, or personal information. Furthermore, we do not store any files on our servers, ensuring your download activity remains completely private."
  },
  {
    q: "Can I convert YouTube videos to MP3 audio?",
    a: "Absolutely! mp4yt serves as a powerful YouTube to MP3 converter. After pasting a YouTube URL and extracting the media, select the audio-only tab or download option. You can download the audio track as a high-quality MP3 file (up to 320kbps), perfect for music, podcasts, or lectures."
  },
  {
    q: "How can I download YouTube videos on my iPhone or Android?",
    a: "mp4yt is fully responsive and works on all mobile devices. For iPhone, paste the link in Safari, tap Extract, choose your quality, and tap Download. You can save it to the Files app via the browser's download manager. For Android, copy the link, paste it in Google Chrome, extract, and download the video directly to your storage."
  },
  {
    q: "Are there any download limits on mp4yt?",
    a: "No, there are zero limits on mp4yt. You can download as many YouTube videos as you like, convert unlimited videos to MP3, and use our extractor for TikTok, Instagram, Twitter, and other platforms without any restrictions or paywalls."
  },
  {
    q: "What other platforms does this video downloader support?",
    a: "While mp4yt is optimized for YouTube, it is a universal media extractor. We support downloading videos, clips, and audio from 1000+ social media and sharing platforms, including Instagram, TikTok, Twitter/X, Facebook, Reddit, Vimeo, Twitch, SoundCloud, Dailymotion, Pinterest, LinkedIn, and more."
  }
];

const { faqs = defaultFaqs } = Astro.props;

// Generate FAQPage Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---

<section id="faq" class="faq-band" aria-labelledby="faq-headline">
  <!-- Structured Data JSON-LD Schema for SEO Search Snippets -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="page-container faq-inner">
    <div class="faq-header">
      <span class="eyebrow">FAQ Section</span>
      <h2 id="faq-headline" class="display-lg faq-title">
        Frequently Asked Questions
      </h2>
      <p class="body-sm faq-desc">
        Got questions about downloading video and audio from YouTube or other platforms? Find all the answers you need about safety, legalities, and quality below.
      </p>
    </div>

    <div class="faq-list">
      {faqs.map((faq) => (
        <details class="faq-item">
          <summary>
            <span class="faq-question">{faq.q}</span>
            <svg class="faq-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </summary>
          <div class="faq-body">
            <p class="body-md">{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-band {
    background-color: var(--color-canvas);
    padding: var(--sp-5xl) var(--sp-lg);
    border-top: var(--border);
  }

  .faq-inner {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: var(--sp-3xl);
    align-items: start;
  }

  .faq-header {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
    position: sticky;
    top: 80px;
  }

  .faq-title {
    margin: 0;
    max-width: 300px;
    color: var(--color-ink);
  }

  .faq-desc {
    margin: 0;
    color: var(--color-mute);
    line-height: 1.6;
  }

  .faq-list {
    border-top: var(--border);
  }

  details.faq-item {
    border-bottom: var(--border);
  }

  details.faq-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-md);
    padding: var(--sp-lg) var(--sp-sm);
    font-family: var(--font-headline);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-ink);
    transition: all 0.1s ease;
    user-select: none;
  }

  details.faq-item summary::-webkit-details-marker { display: none; }
  details.faq-item summary::marker { display: none; }
  
  .faq-question {
    flex: 1;
    text-align: left;
  }

  details.faq-item summary:hover {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    padding-left: var(--sp-md);
    padding-right: var(--sp-md);
  }

  details.faq-item summary:hover .faq-icon {
    color: var(--color-on-primary);
  }

  details.faq-item .faq-body {
    padding: 0 var(--sp-sm) var(--sp-lg) var(--sp-sm);
    color: var(--color-body);
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.6;
    height: 0;
    overflow: hidden;
    transition: height 0.3s ease;
  }

  details.faq-item[open] .faq-body {
    height: auto;
  }

  details.faq-item .faq-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--color-mute);
    transition: transform 0.3s ease;
  }

  details.faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }

  @media (max-width: 992px) {
    .faq-inner {
      grid-template-columns: 1fr;
      gap: var(--sp-xl);
    }

    .faq-header {
      position: static;
      max-width: 100%;
    }

    .faq-title {
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .faq-band {
      padding: var(--sp-4xl) var(--sp-md);
    }
  }

  @media (max-width: 480px) {
    .faq-band {
      padding: var(--sp-3xl) var(--sp-sm);
    }

    details.faq-item summary {
      font-size: 14px;
      padding: var(--sp-md) var(--sp-xs);
    }

    details.faq-item .faq-body {
      font-size: 13px;
      line-height: 1.5;
      padding-bottom: var(--sp-md);
    }
  }
</style>

---
// FAQ Component — Highly SEO-optimized reusable component.
// Automatically renders standard FAQs for the main page or custom ones if passed as props.

interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  faqs?: FAQItem[];
}

const defaultFaqs: FAQItem[] = [
  {
    q: "What is the best free YouTube video downloader in 2026?",
    a: "mp4yt is the best free YouTube video downloader in 2026. It lets you download YouTube videos as MP4 in resolutions up to 4K Ultra HD or convert them to MP3 — all from your browser. No app installation, no account, and no download limits. Unlike other YouTube downloaders that throttle speed or show intrusive ads, mp4yt delivers direct CDN stream links instantly."
  },
  {
    q: "How do I download YouTube videos to MP4 on my phone?",
    a: "To download YouTube videos to MP4 on your phone, copy the video link from the YouTube app, open mp4yt.com in your mobile browser, paste the URL, and tap Extract. Choose your preferred resolution (360p to 4K), then tap Download. On iPhone, save the file via Safari's download manager to the Files app. On Android, the MP4 saves directly to your Downloads folder."
  },
  {
    q: "Can I download Instagram Reels and TikTok videos with this tool?",
    a: "Yes, mp4yt works as a universal video downloader supporting 1000+ platforms. Beyond YouTube, you can download Instagram Reels, TikTok videos without watermark, Twitter/X clips, Facebook videos, Reddit posts with audio, Twitch clips, SoundCloud tracks, and more. Just paste the video URL from any supported platform and click Extract — the same simple process works everywhere."
  },
  {
    q: "Is it safe and legal to use a YouTube downloader online?",
    a: "mp4yt is completely safe to use. It is 100% web-based with no software to install, no malware risk, and no personal data collection. We never store downloaded files on our servers. Regarding legality, downloading videos for personal, offline viewing of non-copyrighted or Creative Commons content is generally considered permissible. Always respect content creators' intellectual property rights."
  },
  {
    q: "How do I convert YouTube videos to MP3 audio?",
    a: "To convert YouTube to MP3, paste any YouTube video URL into mp4yt and click Extract. When the results appear, select the Audio (MP3) option from the quality dropdown. Click Download to save the high-quality MP3 file to your device. This YouTube to MP3 converter is perfect for saving music, podcasts, lectures, and audiobooks for offline listening — no separate app needed."
  },
  {
    q: "Does this video downloader work without installing an app?",
    a: "Yes, mp4yt requires zero installation. It works entirely in your web browser — Chrome, Safari, Firefox, Edge, or any modern browser on any device. There is no desktop software, no browser extension, and no mobile app to download. This makes it the fastest and safest online video downloader available, eliminating risks from third-party software bundles, spyware, or unwanted background processes."
  },
  {
    q: "What video quality and resolution options are available?",
    a: "mp4yt supports every resolution the original video offers: 144p, 240p, 360p, 480p, 720p HD, 1080p Full HD, 1440p 2K, and 2160p 4K Ultra HD. You can also extract audio-only as MP3. The YouTube video downloader delivers direct CDN streams without re-encoding, so the downloaded file matches the exact quality uploaded by the content creator — no compression or quality loss."
  }
];

const { faqs = defaultFaqs } = Astro.props;

// Generate FAQPage Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---

<section id="faq" class="faq-band" aria-labelledby="faq-headline">
  <!-- Structured Data JSON-LD Schema for SEO Search Snippets -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="page-container faq-inner">
    <div class="faq-header">
      <span class="eyebrow">FAQ Section</span>
      <h2 id="faq-headline" class="display-lg faq-title">
        Frequently Asked Questions
      </h2>
      <p class="body-sm faq-desc">
        Got questions about downloading video and audio from YouTube or other platforms? Find all the answers you need about safety, legalities, and quality below.
      </p>
    </div>

    <div class="faq-list">
      {faqs.map((faq) => (
        <details class="faq-item">
          <summary>
            <span class="faq-question">{faq.q}</span>
            <svg class="faq-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </summary>
          <div class="faq-body">
            <p class="body-md">{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-band {
    background-color: var(--color-canvas);
    padding: var(--sp-5xl) var(--sp-lg);
    border-top: var(--border);
  }

  .faq-inner {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: var(--sp-3xl);
    align-items: start;
  }

  .faq-header {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
    position: sticky;
    top: 80px;
  }

  .faq-title {
    margin: 0;
    max-width: 300px;
    color: var(--color-ink);
  }

  .faq-desc {
    margin: 0;
    color: var(--color-mute);
    line-height: 1.6;
  }

  .faq-list {
    border-top: var(--border);
  }

  details.faq-item {
    border-bottom: var(--border);
  }

  details.faq-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-md);
    padding: var(--sp-lg) var(--sp-sm);
    font-family: var(--font-headline);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-ink);
    transition: all 0.1s ease;
    user-select: none;
  }

  details.faq-item summary::-webkit-details-marker { display: none; }
  details.faq-item summary::marker { display: none; }
  
  .faq-question {
    flex: 1;
    text-align: left;
  }

  details.faq-item summary:hover {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    padding-left: var(--sp-md);
    padding-right: var(--sp-md);
  }

  details.faq-item summary:hover .faq-icon {
    color: var(--color-on-primary);
  }

  details.faq-item .faq-body {
    padding: 0 var(--sp-sm) var(--sp-lg) var(--sp-sm);
    color: var(--color-body);
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.6;
    height: 0;
    overflow: hidden;
    transition: height 0.3s ease;
  }

  details.faq-item[open] .faq-body {
    height: auto;
  }

  details.faq-item .faq-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--color-mute);
    transition: transform 0.3s ease;
  }

  details.faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }

  @media (max-width: 992px) {
    .faq-inner {
      grid-template-columns: 1fr;
      gap: var(--sp-xl);
    }

    .faq-header {
      position: static;
      max-width: 100%;
    }

    .faq-title {
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .faq-band {
      padding: var(--sp-4xl) var(--sp-md);
    }
  }

  @media (max-width: 480px) {
    .faq-band {
      padding: var(--sp-3xl) var(--sp-sm);
    }

    details.faq-item summary {
      font-size: 14px;
      padding: var(--sp-md) var(--sp-xs);
    }

    details.faq-item .faq-body {
      font-size: 13px;
      line-height: 1.5;
      padding-bottom: var(--sp-md);
    }
  }
</style>

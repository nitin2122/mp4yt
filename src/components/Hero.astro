---
// Hero section — Brutalist terminal-style video downloader with massive headline
import PlatformSwitcher from "./PlatformSwitcher.astro";
---

<section id="hero" class="hero-band" aria-labelledby="hero-headline">
  <div class="page-container hero-content">
    <!-- Massive Headline -->
    <h1 id="hero-headline" class="display-xl hero-headline">
      VIDEO<br />DOWNLOADER
    </h1>

    <!-- Brutalist eyebrow tag -->
    <p class="hero-eyebrow-tag">BRUTALIST EDITION. INSTANT. ZERO FRICTION.</p>

    <!-- Subhead -->
    <p class="body-md hero-subhead">
      The #1 free <strong>YT video downloader</strong> online. Paste a link from YouTube,
      Instagram, TikTok, Twitter/X, or 1000+ platforms. Get the direct MP4 stream
      — zero waiting.
    </p>

    <!-- Main Terminal Interface -->
    <div class="terminal-container hard-shadow-lg">
      <PlatformSwitcher currentPlatform="General" />
      <!-- URL Bar -->
      <form
        id="extract-form"
        class="terminal-url-bar"
        aria-label="Video URL extractor"
        novalidate
      >
        <div class="input-group">
          <span class="terminal-prompt" aria-hidden="true">&gt;</span>
          <input
            id="hero-input"
            type="url"
            class="hero-url-input"
            placeholder="PASTE URL..."
            aria-label="Video URL"
            autocomplete="off"
            spellcheck="false"
            enterkeyhint="go"
          />
          <button
            id="extract-btn"
            type="submit"
            class="extract-btn"
            aria-label="Extract video"
          >
            <svg
              id="extract-icon"
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M7 1v8M4 6l3 3 3-3M2 11h10"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <svg
              id="extract-spinner"
              class="animate-spin hidden"
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              aria-hidden="true"
            >
              <circle
                cx="7"
                cy="7"
                r="5"
                stroke="rgba(255,255,255,0.3)"
                stroke-width="2"></circle>
              <path
                d="M7 2a5 5 0 0 1 5 5"
                stroke="white"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
            <span id="extract-btn-label">EXTRACT</span>
          </button>
        </div>

        <!-- Loading progress bar -->
        <div
          id="progress-bar"
          class="progress-bar-track hidden"
          role="progressbar"
          aria-label="Loading…"
        >
          <div class="progress-bar-fill"></div>
        </div>

        <!-- Error message -->
        <div
          id="error-msg"
          class="error-msg hidden"
          role="alert"
          aria-live="assertive"
        >
        </div>
      </form>

      <!-- Decorative terminal status line -->
      <div class="terminal-status" aria-hidden="true">
        <span class="terminal-status-text">COBALT_ENGINE_v4.2</span>
        <span class="terminal-status-dot"></span>
        <span class="terminal-status-text">API_STATUS: NOMINAL</span>
      </div>
    </div>

    <!-- Paste hint -->
    <p class="paste-hint body-sm" aria-live="polite" id="paste-hint">
      <span class="paste-desktop"
        ><kbd class="kbd">Ctrl+V</kbd> TO PASTE — AUTO-DETECT ENABLED</span
      >
      <span class="paste-mobile">TAP INPUT AND PASTE YOUR URL</span>
    </p>

    <!-- Trust signals -->
    <div class="hero-trust" role="list" aria-label="Key features">
      <div class="trust-chip" role="listitem">NO_REGISTRATION</div>
      <div class="trust-chip" role="listitem">NO_FILE_STORAGE</div>
      <div class="trust-chip" role="listitem">INSTANT_CDN_STREAM</div>
    </div>
  </div>
</section>

<!-- Result Card Section (hidden until response) -->
<div
  id="result-section"
  class="result-section hidden"
  aria-live="polite"
  aria-label="Video extraction result"
>
  <div class="page-container">
    <div id="result-card" class="result-card animate-fade-in-up">
      <div class="result-inner">
        <!-- Thumbnail + Preview -->
        <div class="result-media">
          <div class="thumbnail-wrapper">
            <img
              id="result-thumb"
              src=""
              alt=""
              class="result-thumb"
              loading="lazy"
            />
            <div class="thumb-overlay" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <rect width="40" height="40" fill="rgba(0,0,0,0.5)"></rect>
                <path d="M16 13l14 7-14 7V13z" fill="white"></path>
              </svg>
            </div>
          </div>
        </div>

        <!-- Metadata + Actions -->
        <div class="result-meta">
          <div class="result-header">
            <span class="eyebrow" id="result-platform">Instagram</span>
            <h2 id="result-title" class="display-sm result-title"></h2>
          </div>

          <div class="result-stats">
            <div class="stat-item">
              <svg
                width="14"
                height="14"
                viewBox="0 0 14 14"
                fill="none"
                aria-hidden="true"
              >
                <circle
                  cx="7"
                  cy="7"
                  r="5"
                  stroke="var(--color-mute)"
                  stroke-width="1.3"></circle>
                <path
                  d="M7 4.5V7l2 1.5"
                  stroke="var(--color-mute)"
                  stroke-width="1.3"
                  stroke-linecap="round"></path>
              </svg>
              <span id="result-duration" class="data-mono"></span>
            </div>
            <div class="stat-item">
              <span class="data-mono">BEST QUALITY MP4</span>
            </div>
          </div>

          <!-- Quality Dropdown -->
          <div class="result-resolutions">
            <span class="eyebrow">SELECT RESOLUTION</span>
            <div class="quality-dropdown-container">
              <button
                id="quality-dropdown-trigger"
                class="quality-dropdown-trigger"
                aria-haspopup="listbox"
                aria-expanded="false"
                type="button"
              >
                <span class="dropdown-trigger-icon">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <rect x="2" y="2" width="12" height="12" stroke-width="1.5"
                    ></rect>
                    <path d="M5 8.5h6M5 11.5h6M5 5.5h6" stroke-linecap="round"
                    ></path>
                  </svg>
                </span>
                <span id="quality-trigger-text">SELECT QUALITY</span>
                <span class="dropdown-chevron">
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 12 12"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      d="M3 4.5l3 3 3-3"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </span>
              </button>
              <div
                id="quality-dropdown-menu"
                class="quality-dropdown-menu hidden"
                role="listbox"
              >
                <!-- Dynamically populated options -->
              </div>
            </div>
          </div>

          <div class="result-filename">
            <span class="eyebrow">FILENAME</span>
            <code id="result-filename-display" class="code filename-code"
            ></code>
          </div>

          <div class="result-actions">
            <a
              id="result-download-btn"
              href="#result-container"
              class="btn-primary btn-primary-lg"
              download
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M8 2v8M5 7l3 3 3-3M2 13h12"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              DOWNLOAD MP4
            </a>
            <button
              class="btn-secondary"
              id="copy-url-btn"
              aria-label="Copy direct URL"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <rect
                  x="5"
                  y="5"
                  width="8"
                  height="8"
                  stroke="currentColor"
                  stroke-width="1.3"></rect>
                <path
                  d="M11 5V4a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h1"
                  stroke="currentColor"
                  stroke-width="1.3"
                  stroke-linecap="round"></path>
              </svg>
              COPY URL
            </button>
          </div>

          <!-- Inline video preview -->
          <details class="video-preview-toggle">
            <summary class="body-sm-strong preview-summary">
              <svg
                width="14"
                height="14"
                viewBox="0 0 14 14"
                fill="none"
                aria-hidden="true"
              >
                <rect
                  x="2"
                  y="2.5"
                  width="10"
                  height="9"
                  stroke="currentColor"
                  stroke-width="1.2"></rect>
                <path d="M5.5 5.5L8.5 7l-3 1.5v-3z" fill="currentColor"></path>
              </svg>
              PREVIEW VIDEO IN BROWSER
            </summary>
            <div class="video-preview-wrapper">
              <video
                id="result-video"
                controls
                preload="metadata"
                class="result-video"
              >
                Your browser does not support the video tag.
              </video>
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Hero Band */
  .hero-band {
    position: relative;
    background-color: var(--color-canvas);
    padding: var(--sp-4xl) var(--sp-lg) var(--sp-5xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    max-width: 100vw;
    border-bottom: var(--border);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--sp-lg);
  }

  .hero-headline {
    margin: 0;
    max-width: 900px;
    color: var(--color-ink);
  }

  .hero-eyebrow-tag {
    display: inline-block;
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 16px;
    margin: 0;
  }

  .hero-subhead {
    margin: 0;
    max-width: 600px;
    color: var(--color-body);
    text-transform: none;
  }

  /* Terminal Container */
  .terminal-container {
    width: 100%;
    max-width: 800px;
    border: var(--border);
    background-color: var(--color-primary);
    padding: 2px;
    margin-top: var(--sp-sm);
  }

  .terminal-url-bar {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .input-group {
    display: flex;
    align-items: center;
    background-color: var(--color-canvas);
    border-bottom: var(--border);
    min-width: 0;
    max-width: 100%;
    box-sizing: border-box;
  }

  .terminal-prompt {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-primary);
    padding: 0 var(--sp-sm) 0 var(--sp-md);
    flex-shrink: 0;
  }

  .hero-url-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink);
    padding: var(--sp-md) var(--sp-sm) var(--sp-md) 0;
    text-transform: uppercase;
    min-width: 0;
    letter-spacing: 0.02em;
  }

  .hero-url-input::placeholder {
    color: var(--color-mute);
    opacity: 0.5;
    text-transform: uppercase;
  }

  .extract-btn {
    border: none;
    border-left: var(--border);
    background-color: var(--color-canvas);
    color: var(--color-ink);
    height: 54px;
    padding: 0 var(--sp-xl);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    flex-shrink: 0;
    gap: var(--sp-xs);
    display: inline-flex;
    align-items: center;
    transition: all 0.1s ease;
  }

  .extract-btn:hover {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  /* Terminal status line */
  .terminal-status {
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
    padding: var(--sp-xs) var(--sp-md);
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .terminal-status-dot {
    width: 6px;
    height: 6px;
    background-color: #28c840;
    animation: statusPulse 2s ease-in-out infinite;
  }

  @keyframes statusPulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }

  /* Progress bar */
  .progress-bar-track {
    margin: 0;
    border: none;
    background-color: var(--color-canvas-soft-2);
  }

  /* Error */
  .error-msg {
    padding: var(--sp-xs) var(--sp-md);
    background-color: var(--color-error-soft);
    border: var(--border);
    border-color: var(--color-error);
    color: var(--color-error-deep);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.4;
    text-transform: uppercase;
  }

  /* Paste hint */
  .paste-hint {
    margin: 0;
    color: var(--color-mute);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .paste-mobile {
    display: none;
  }
  .paste-desktop {
    display: inline;
  }

  @media (max-width: 768px) {
    .paste-mobile {
      display: inline;
    }
    .paste-desktop {
      display: none;
    }
  }

  .kbd {
    display: inline-flex;
    align-items: center;
    background-color: var(--color-canvas-soft-2);
    border: var(--border);
    padding: 1px 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink);
  }

  /* Trust signals */
  .hero-trust {
    display: flex;
    align-items: center;
    gap: var(--sp-xs);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--sp-xs);
  }

  .trust-chip {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 12px;
    border: var(--border);
    color: var(--color-ink);
    background: var(--color-canvas);
  }

  /* Result Section */
  .result-section {
    background-color: var(--color-canvas);
    padding: var(--sp-4xl) 0;
    border-bottom: var(--border);
  }

  .result-card {
    border: var(--border);
    box-shadow: var(--shadow-3);
    padding: var(--sp-xl);
    background-color: var(--color-canvas);
    overflow: hidden;
  }

  .result-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--sp-xl);
    align-items: start;
  }

  .result-media {
    position: relative;
  }

  .thumbnail-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16/9;
    background-color: var(--color-canvas-soft-2);
    border: var(--border);
  }

  .result-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.1);
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .thumbnail-wrapper:hover .thumb-overlay {
    opacity: 1;
  }

  .result-meta {
    display: flex;
    flex-direction: column;
    gap: var(--sp-lg);
  }

  .result-header {
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
  }

  .result-title {
    margin: 0;
    color: var(--color-ink);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .result-stats {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .result-filename {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .filename-code {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-body);
    background-color: var(--color-canvas-soft-2);
    border: var(--border-thin);
    padding: var(--sp-xs) var(--sp-sm);
    word-break: break-all;
    display: block;
  }

  .result-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
    flex-wrap: wrap;
  }

  /* Video preview toggle */
  .video-preview-toggle {
    border: none;
  }

  .preview-summary {
    display: flex;
    align-items: center;
    gap: var(--sp-xs);
    cursor: pointer;
    color: var(--color-ink);
    list-style: none;
    padding: var(--sp-xs) 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.1s ease;
  }

  .preview-summary:hover {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    padding-left: var(--sp-sm);
    padding-right: var(--sp-sm);
  }
  .preview-summary::-webkit-details-marker {
    display: none;
  }

  .video-preview-wrapper {
    margin-top: var(--sp-sm);
    border: var(--border);
    overflow: hidden;
    background: #000;
  }

  .result-video {
    width: 100%;
    max-height: 360px;
    display: block;
  }

  .result-resolutions {
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
    margin-top: var(--sp-xs);
  }

  /* Quality select dropdown */
  .quality-dropdown-container {
    position: relative;
    width: 100%;
  }

  .quality-dropdown-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 48px;
    padding: 0 var(--sp-md);
    background-color: var(--color-canvas);
    border: var(--border);
    color: var(--color-ink);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    transition: all 0.1s ease;
  }

  .quality-dropdown-trigger:hover,
  .quality-dropdown-trigger.active {
    background-color: var(--color-canvas-soft-2);
  }

  .dropdown-trigger-icon {
    display: flex;
    align-items: center;
    color: var(--color-mute);
  }

  #quality-trigger-text {
    flex: 1;
    text-align: left;
    margin-left: var(--sp-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dropdown-chevron {
    display: flex;
    align-items: center;
    color: var(--color-mute);
    transition: transform 0.2s ease;
  }

  .quality-dropdown-trigger.active .dropdown-chevron {
    transform: rotate(180deg);
  }

  .quality-dropdown-menu {
    position: absolute;
    top: calc(100% + 2px);
    left: 0;
    right: 0;
    z-index: 100;
    max-height: 280px;
    overflow-y: auto;
    background: var(--color-canvas);
    border: var(--border);
    display: flex;
    flex-direction: column;
    padding: 4px;
    gap: 2px;
    box-shadow: var(--shadow-3);
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-xs) var(--sp-sm);
    border: none;
    background: transparent;
    color: var(--color-ink);
    cursor: pointer;
    text-align: left;
    width: 100%;
    font-family: var(--font-mono);
    transition: all 0.1s ease;
  }

  .dropdown-item:hover {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
  }

  .dropdown-item.active {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    font-weight: 700;
  }

  .opt-info {
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
  }

  .opt-res {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .opt-badge {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    padding: 2px 6px;
    border: var(--border);
    color: var(--color-ink);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: transparent;
  }

  .dropdown-item.active .opt-badge {
    border-color: var(--color-on-primary);
    color: var(--color-on-primary);
  }

  .opt-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
  }

  .opt-size {
    font-size: 12px;
    color: var(--color-mute);
  }

  .dropdown-item.active .opt-size {
    color: var(--color-on-primary);
    opacity: 0.7;
  }

  .opt-audio {
    display: inline-flex;
    align-items: center;
    font-size: 11px;
  }

  .opt-audio.has-audio {
    color: #28c840;
  }

  .opt-audio.no-audio {
    color: var(--color-mute);
  }

  .dropdown-item.active .opt-audio.has-audio {
    color: var(--color-on-primary);
  }

  .dropdown-item:hover .opt-badge {
    border-color: var(--color-on-primary);
    color: var(--color-on-primary);
  }

  .dropdown-item:hover .opt-size {
    color: var(--color-on-primary);
    opacity: 0.7;
  }

  .dropdown-item:hover .opt-audio {
    color: var(--color-on-primary);
  }

  .hidden {
    display: none !important;
  }

  @media (max-width: 768px) {
    .hero-band {
      padding: var(--sp-3xl) var(--sp-md) var(--sp-3xl);
    }
    .result-inner {
      grid-template-columns: 1fr;
    }
    .hero-content {
      gap: var(--sp-md);
      min-width: 0;
      max-width: 100%;
    }
    .result-section {
      padding: var(--sp-xl) 0;
    }
    .filename-code {
      font-size: 11px;
      word-break: break-all;
      overflow-wrap: anywhere;
    }
    .quality-dropdown-menu {
      max-height: 220px;
    }
    .quality-dropdown-trigger {
      height: 44px;
      font-size: 12px;
    }
    .opt-meta {
      flex-direction: column;
      align-items: flex-end;
      gap: 4px;
    }
  }

  /* ── Stacked mobile layout (≤640px) ── */
  @media (max-width: 640px) {
    .hero-band {
      padding: var(--sp-3xl) var(--sp-md) var(--sp-2xl);
    }
    .input-group {
      flex-direction: column;
      background: var(--color-canvas);
      border: none;
      gap: 0;
      overflow: visible;
      max-width: 100%;
    }
    .terminal-prompt {
      display: none;
    }
    .hero-url-input {
      background-color: var(--color-canvas);
      border: var(--border);
      padding: var(--sp-md);
      width: 100%;
      max-width: 100%;
      height: 50px;
      font-size: 14px;
      box-sizing: border-box;
    }
    .hero-url-input:focus {
      box-shadow: var(--shadow-3);
    }
    .extract-btn {
      width: 100%;
      max-width: 100%;
      justify-content: center;
      padding: 0 var(--sp-md);
      height: 50px;
      min-height: 50px;
      font-size: 14px;
      font-weight: 700;
      background-color: var(--color-primary);
      color: var(--color-on-primary);
      border: var(--border);
      border-left: var(--border);
      display: inline-flex;
      align-items: center;
      box-sizing: border-box;
      margin-top: -2px; /* overlap borders */
    }
    .extract-btn:active {
      transform: scale(0.98);
    }
    .hero-trust {
      gap: var(--sp-xs);
    }
    .trust-chip {
      font-size: 9px;
      padding: 3px 8px;
    }
    .result-actions {
      flex-direction: column;
    }
    .result-actions .btn-primary,
    .result-actions .btn-secondary {
      width: 100%;
      justify-content: center;
      min-height: 44px;
    }
    .paste-hint {
      font-size: 11px;
    }
    .hero-subhead {
      font-size: 13px;
      line-height: 1.5;
    }
    .result-card {
      padding: var(--sp-md);
    }
    .result-inner {
      gap: var(--sp-md);
    }
    .dropdown-item {
      padding: var(--sp-sm) var(--sp-sm);
      min-height: 44px;
    }
    .terminal-container {
      box-shadow: var(--shadow-3);
    }
  }

  @media (max-width: 400px) {
    .hero-band {
      padding: var(--sp-2xl) var(--sp-sm) var(--sp-xl);
    }
  }
</style>

<script>
  const form = document.getElementById("extract-form") as HTMLFormElement;
  const input = document.getElementById("hero-input") as HTMLInputElement;
  const extractBtn = document.getElementById(
    "extract-btn",
  ) as HTMLButtonElement;
  const extractIcon = document.getElementById(
    "extract-icon",
  ) as unknown as SVGElement;
  const extractSpinner = document.getElementById(
    "extract-spinner",
  ) as unknown as SVGElement;
  const extractBtnLabel = document.getElementById(
    "extract-btn-label",
  ) as HTMLSpanElement;
  const progressBar = document.getElementById("progress-bar") as HTMLDivElement;
  const errorMsg = document.getElementById("error-msg") as HTMLDivElement;
  const pasteHint = document.getElementById(
    "paste-hint",
  ) as HTMLParagraphElement;

  const resultSection = document.getElementById(
    "result-section",
  ) as HTMLDivElement;
  const resultThumb = document.getElementById(
    "result-thumb",
  ) as HTMLImageElement;
  const resultTitle = document.getElementById(
    "result-title",
  ) as HTMLHeadingElement;
  const resultDuration = document.getElementById(
    "result-duration",
  ) as HTMLSpanElement;
  const resultFilename = document.getElementById(
    "result-filename-display",
  ) as HTMLElement;
  const resultDownloadBtn = document.getElementById(
    "result-download-btn",
  ) as HTMLAnchorElement;
  const copyUrlBtn = document.getElementById(
    "copy-url-btn",
  ) as HTMLButtonElement;
  const resultVideo = document.getElementById(
    "result-video",
  ) as HTMLVideoElement;
  const resultPlatform = document.getElementById(
    "result-platform",
  ) as HTMLSpanElement;
  const triggerBtn = document.getElementById(
    "quality-dropdown-trigger",
  ) as HTMLButtonElement;
  const dropdownMenu = document.getElementById(
    "quality-dropdown-menu",
  ) as HTMLDivElement;
  const triggerText = document.getElementById(
    "quality-trigger-text",
  ) as HTMLSpanElement;

  // ── Hash URL autofill (from seo-handler redirect: /#url=...) ──
  function checkHashUrl() {
    const hash = window.location.hash;
    if (hash.startsWith("#url=")) {
      const encodedUrl = hash.slice(5);
      try {
        const url = decodeURIComponent(encodedUrl);
        input.value = url;
        // Clean the hash from the URL bar
        history.replaceState(null, "", window.location.pathname);
        // Auto-trigger extraction
        setTimeout(() => extractVideo(url), 300);
      } catch (e) {
        /* invalid encoding, ignore */
      }
    }
  }

  // ── Auto-paste detection ──
  document.addEventListener("paste", (e: ClipboardEvent) => {
    const text = e.clipboardData?.getData("text/plain")?.trim() ?? "";
    if (text && isValidUrl(text) && document.activeElement !== input) {
      input.value = text;
      extractVideo(text);
    }
  });

  // ── Form submission ──
  form.addEventListener("submit", (e: Event) => {
    e.preventDefault();
    const url = input.value.trim();
    if (!url) return;
    if (!isValidUrl(url)) {
      showError(
        "Please paste a valid video URL (e.g. https://instagram.com/p/...)",
      );
      return;
    }
    extractVideo(url);
  });

  function isValidUrl(url: string): boolean {
    try {
      const u = new URL(url);
      return u.protocol === "http:" || u.protocol === "https:";
    } catch {
      return false;
    }
  }

  function setLoading(loading: boolean) {
    extractBtn.disabled = loading;
    extractIcon.classList.toggle("hidden", loading);
    extractSpinner.classList.toggle("hidden", !loading);
    extractBtnLabel.textContent = loading ? "EXTRACTING…" : "EXTRACT";
    progressBar.classList.toggle("hidden", !loading);
    if (loading) {
      errorMsg.classList.add("hidden");
    }
  }

  function showError(msg: string) {
    errorMsg.textContent = msg;
    errorMsg.classList.remove("hidden");
    resultSection.classList.add("hidden");
  }

  function formatDuration(seconds: number): string {
    if (!seconds || isNaN(seconds)) return "Unknown duration";
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = Math.floor(seconds % 60);
    if (h > 0)
      return `${h}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
    return `${m}:${String(s).padStart(2, "0")}`;
  }

  function getPlatformName(url: string): string {
    try {
      const host = new URL(url).hostname.replace("www.", "");
      const map: Record<string, string> = {
        "instagram.com": "Instagram",
        "tiktok.com": "TikTok",
        "twitter.com": "Twitter/X",
        "x.com": "Twitter/X",
        "facebook.com": "Facebook",
        "fb.com": "Facebook",
        "reddit.com": "Reddit",
        "vimeo.com": "Vimeo",
        "twitch.tv": "Twitch",
        "soundcloud.com": "SoundCloud",
        "dailymotion.com": "Dailymotion",
      };
      return map[host] ?? host;
    } catch {
      return "Video";
    }
  }

  // Helper to format bytes to human readable string
  function formatBytes(bytes: number, decimals = 1): string {
    if (bytes === 0) return "0 Bytes";
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ["Bytes", "KB", "MB", "GB"];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + " " + sizes[i];
  }

  // Helper to sanitize filenames on frontend
  function sanitizeFilename(title: string): string {
    if (!title || typeof title !== "string") return "video";
    return (
      title
        .toLowerCase()
        .replace(/[^a-z0-9\s\-_]/g, "")
        .trim()
        .replace(/\s+/g, "-")
        .replace(/-+/g, "-")
        .slice(0, 120) || "video"
    );
  }

  // Helper to format filenames with resolutions
  function getFilenameWithRes(title: string, res: string, ext: string): string {
    const cleanRes = res.toLowerCase().replace(/[^a-z0-9]/g, "");
    const sanitized = sanitizeFilename(title);
    return `${sanitized}-${cleanRes}.${ext}`;
  }

  // Store the raw CDN stream URL separately for the video preview player
  let currentStreamUrl = "";
  let currentFilename = "video.mp4";

  async function extractVideo(url: string) {
    setLoading(true);
    try {
      const resp = await fetch(`/api/extract?url=${encodeURIComponent(url)}`);
      const data = await resp.json();

      if (!resp.ok) {
        showError(
          data.error ??
            "Failed to extract video. Please check the URL and try again.",
        );
        return;
      }

      // Populate result card
      const platformName = getPlatformName(url);
      resultPlatform.textContent = platformName;
      resultTitle.textContent = data.title ?? "Untitled video";
      resultDuration.textContent = formatDuration(data.duration);
      currentFilename = data.filename ?? "video.mp4";
      resultFilename.textContent = currentFilename;
      resultThumb.src = data.thumbnail ?? "";
      resultThumb.alt = data.title ?? "Video thumbnail";

      // Store the CDN stream URL and build download URL
      currentStreamUrl = data.url;
      const downloadUrl = `/download-stream?url=${encodeURIComponent(data.url)}&filename=${encodeURIComponent(currentFilename)}`;
      resultDownloadBtn.href = downloadUrl;
      resultDownloadBtn.setAttribute("download", currentFilename);

      // Video preview uses raw stream URL directly (plays inline)
      resultVideo.src = currentStreamUrl;

      // Populate resolution options dropdown
      dropdownMenu.innerHTML = "";
      if (Array.isArray(data.formats) && data.formats.length > 0) {
        let selectedFormat = data.formats[0];

        const updateSelectedFormat = (fmt: any) => {
          selectedFormat = fmt;
          const label = fmt.resolution;
          const sizeStr = fmt.filesize
            ? formatBytes(fmt.filesize)
            : "Unknown size";
          triggerText.textContent = `${label} (${fmt.ext} · ${sizeStr})`;

          currentStreamUrl = fmt.url;
          const specificFilename = getFilenameWithRes(
            data.title || "video",
            fmt.resolution,
            fmt.ext,
          );
          let rowDownloadUrl = `/download-stream?url=${encodeURIComponent(fmt.url)}&filename=${encodeURIComponent(specificFilename)}`;
          if (fmt.audio_url) {
            rowDownloadUrl += `&audioUrl=${encodeURIComponent(fmt.audio_url)}`;
          }
          resultDownloadBtn.href = rowDownloadUrl;
          resultDownloadBtn.setAttribute("download", specificFilename);
          currentFilename = specificFilename;
          resultFilename.textContent = specificFilename;

          // Video preview uses raw stream URL directly (plays inline)
          resultVideo.src = fmt.url;

          // Modify download button text
          resultDownloadBtn.innerHTML = `
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M8 2v8M5 7l3 3 3-3M2 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            DOWNLOAD ${fmt.resolution}
          `;

          // Mark active item in dropdown
          const items = dropdownMenu.querySelectorAll(".dropdown-item");
          items.forEach((item: any) => {
            const itemRes = item.getAttribute("data-res");
            if (itemRes === fmt.resolution) {
              item.classList.add("active");
              item.setAttribute("aria-selected", "true");
            } else {
              item.classList.remove("active");
              item.setAttribute("aria-selected", "false");
            }
          });
        };

        data.formats.forEach((fmt: any) => {
          const item = document.createElement("button");
          item.className = "dropdown-item";
          item.type = "button";
          item.role = "option";
          item.setAttribute("data-res", fmt.resolution);
          item.setAttribute("data-ext", fmt.ext);

          const sizeLabel = fmt.filesize
            ? formatBytes(fmt.filesize)
            : "Unknown size";
          const audioIcon = fmt.has_audio
            ? `<span class="opt-audio has-audio" title="Contains Audio"><svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" style="display:inline-block;vertical-align:middle;margin-right:4px;"><path d="M8 2a.75.75 0 01.19.46v10.58a.75.75 0 01-1.28.53L3.69 10.5H1.75A.75.75 0 011 9.75V6.25A.75.75 0 011.75 5.5h1.94l3.22-3.28A.75.75 0 018 2zm3.3 3.2a.75.75 0 111.1 1.02 3.5 3.5 0 010 4.56.75.75 0 11-1.1 1.02 5 5 0 000-6.6zM13.8 2.7a.75.75 0 111.1 1.02 8 8 0 010 9.56.75.75 0 11-1.1 1.02 9.5 9.5 0 000-11.6z"/></svg>Video + Audio</span>`
            : `<span class="opt-audio no-audio" title="No Audio (Muted)"><svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" style="display:inline-block;vertical-align:middle;margin-right:4px;"><path d="M6.5 1.75a.75.75 0 01.19.46v11.58a.75.75 0 01-1.28.53L2.19 11H.75A.75.75 0 010 10.25V5.75A.75.75 0 01.75 5h1.44l3.22-3.28a.75.75 0 01.59-.22zM12.44 8l1.78-1.78a.75.75 0 00-1.06-1.06L11.38 6.94l-1.78-1.78a.75.75 0 00-1.06 1.06L10.32 8l-1.78 1.78a.75.75 0 001.06 1.06l1.78-1.78 1.78 1.78a.75.75 0 001.06-1.06L12.44 8z"/></svg>Video Only</span>`;

          item.innerHTML = `
            <div class="opt-info">
              <span class="opt-res">${fmt.resolution}</span>
              <span class="opt-badge">${fmt.ext}</span>
            </div>
            <div class="opt-meta">
              <span class="opt-size">${sizeLabel}</span>
              ${audioIcon}
            </div>
          `;

          item.addEventListener("click", () => {
            updateSelectedFormat(fmt);
            dropdownMenu.classList.add("hidden");
            triggerBtn.classList.remove("active");
            triggerBtn.setAttribute("aria-expanded", "false");
          });

          dropdownMenu.appendChild(item);
        });

        // Initialize with default selection
        updateSelectedFormat(selectedFormat);
      }

      // Show result
      resultSection.classList.remove("hidden");
      resultSection.scrollIntoView({ behavior: "smooth", block: "start" });

      // Clear hash if any
      history.replaceState(null, "", window.location.pathname);
    } catch (err) {
      showError("Network error — please try again.");
    } finally {
      setLoading(false);
    }
  }

  // Toggle quality select dropdown
  if (triggerBtn && dropdownMenu) {
    triggerBtn.addEventListener("click", (e: Event) => {
      e.stopPropagation();
      const isHidden = dropdownMenu.classList.contains("hidden");
      dropdownMenu.classList.toggle("hidden", !isHidden);
      triggerBtn.classList.toggle("active", isHidden);
      triggerBtn.setAttribute("aria-expanded", isHidden ? "true" : "false");
    });

    // Close when clicking outside
    document.addEventListener("click", (e: Event) => {
      if (
        !triggerBtn.contains(e.target as Node) &&
        !dropdownMenu.contains(e.target as Node)
      ) {
        dropdownMenu.classList.add("hidden");
        triggerBtn.classList.remove("active");
        triggerBtn.setAttribute("aria-expanded", "false");
      }
    });
  }

  // Native streaming download button
  resultDownloadBtn.addEventListener("click", (e: Event) => {
    e.preventDefault();
    const downloadUrl = resultDownloadBtn.href;
    if (!downloadUrl || downloadUrl === "#") return;

    window.location.href = downloadUrl;

    const origHTML = resultDownloadBtn.innerHTML;
    resultDownloadBtn.innerHTML = `
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" style="display:inline-block;vertical-align:middle;margin-right:6px;">
        <path d="M2 8l4 4L14 3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      DOWNLOAD STARTED
    `;
    (resultDownloadBtn as any).style.pointerEvents = "none";

    setTimeout(() => {
      resultDownloadBtn.innerHTML = origHTML;
      (resultDownloadBtn as any).style.pointerEvents = "";
    }, 4000);
  });

  // Copy URL button
  copyUrlBtn.addEventListener("click", async () => {
    if (!currentStreamUrl) return;
    try {
      await navigator.clipboard.writeText(currentStreamUrl);
      const prev = copyUrlBtn.innerHTML;
      copyUrlBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4L14 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> COPIED!`;
      setTimeout(() => {
        copyUrlBtn.innerHTML = prev;
      }, 2000);
    } catch {
      /* fallback */
    }
  });

  // Init on load
  checkHashUrl();
</script>

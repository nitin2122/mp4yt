---
// Features section — 3-up card grid with Vercel card-marketing chrome
---

<section id="features" class="features-band" aria-labelledby="features-headline">
  <div class="page-container">
    <div class="features-header">
      <span class="eyebrow">Why mp4yt</span>
      <h2 id="features-headline" class="display-lg features-title">
        Built different. Built better.
      </h2>
      <p class="body-lg features-subtitle">
        No mirrors, no muxing delays, no file servers. Just a clean serverless pipeline
        that fetches the direct CDN URL and hands it straight to your browser.
      </p>
    </div>

    <div class="features-grid">
      <!-- Feature 1: Zero Storage -->
      <article class="feature-card card" aria-labelledby="feat-1-title">
        <div class="feat-icon-wrap feat-icon-blue" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5z" stroke="currentColor" stroke-width="1.4"/>
            <path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 id="feat-1-title" class="display-sm feat-title">Zero disk storage.</h3>
        <p class="body-md feat-desc">
          We never save your video on any server. The backend acts as a pure metadata proxy —
          it reads the CDN stream URL and immediately passes it to your browser.
          Your data stays yours.
        </p>
        <div class="feat-tag">
          <span class="caption-mono" style="color: var(--color-mute);">privacy-first</span>
        </div>
      </article>

      <!-- Feature 2: Instant CDN -->
      <article class="feature-card card" aria-labelledby="feat-2-title">
        <div class="feat-icon-wrap feat-icon-violet" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 3v3M10 14v3M3 10h3M14 10h3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.4"/>
            <path d="M5.6 5.6l1.8 1.8M12.6 12.6l1.8 1.8M5.6 14.4l1.8-1.8M12.6 7.4l1.8-1.8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 id="feat-2-title" class="display-sm feat-title">Direct CDN stream.</h3>
        <p class="body-md feat-desc">
          Get the actual streaming URL from the platform's CDN — the same link the platform
          uses to serve the video to you. No re-encoding, no extra hops, maximum speed.
        </p>
        <div class="feat-tag">
          <span class="caption-mono" style="color: var(--color-mute);">serverless · edge</span>
        </div>
      </article>

      <!-- Feature 3: 1000+ Platforms -->
      <article class="feature-card card" aria-labelledby="feat-3-title">
        <div class="feat-icon-wrap feat-icon-pink" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.4"/>
            <path d="M10 3c0 0-3 2-3 7s3 7 3 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M10 3c0 0 3 2 3 7s-3 7-3 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M3 10h14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 id="feat-3-title" class="display-sm feat-title">1000+ platforms.</h3>
        <p class="body-md feat-desc">
          Powered by Cobalt, the world's most comprehensive media downloader engine.
          Instagram, TikTok, Twitter/X, Reddit, Vimeo, Twitch — paste any URL.
        </p>
        <div class="feat-tag">
          <span class="caption-mono" style="color: var(--color-mute);">Cobalt powered</span>
        </div>
      </article>

      <!-- Feature 4: Auto-paste -->
      <article class="feature-card card" aria-labelledby="feat-4-title">
        <div class="feat-icon-wrap feat-icon-teal" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="5" y="3" width="10" height="14" rx="2" stroke="currentColor" stroke-width="1.4"/>
            <path d="M8 3.5v-1a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M8 9h4M8 12h2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 id="feat-4-title" class="display-sm feat-title">Smart auto-paste.</h3>
        <p class="body-md feat-desc">
          Copy a video URL anywhere on your device and press <kbd class="kbd-inline">Ctrl+V</kbd>
          anywhere on our page. We detect the clipboard content and begin extraction automatically
          — no need to click the input field.
        </p>
        <div class="feat-tag">
          <span class="caption-mono" style="color: var(--color-mute);">ux · clipboard api</span>
        </div>
      </article>

      <!-- Feature 5: Dynamic SEO -->
      <article class="feature-card card" aria-labelledby="feat-5-title">
        <div class="feat-icon-wrap feat-icon-amber" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 4h12v12H4z" stroke="currentColor" stroke-width="1.4" rx="2"/>
            <path d="M4 8h12M8 8v8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </div>
        <h3 id="feat-5-title" class="display-sm feat-title">Smart link sharing.</h3>
        <p class="body-md feat-desc">
          Share a <code class="code-inline">/watch?url=</code> link anywhere. Bots get a beautifully
          rendered OpenGraph preview with the real video title and thumbnail. Humans get
          instantly redirected to the app with the URL pre-filled.
        </p>
        <div class="feat-tag">
          <span class="caption-mono" style="color: var(--color-mute);">edge seo · opengraph</span>
        </div>
      </article>

      <!-- Feature 6: No Registration -->
      <article class="feature-card card" aria-labelledby="feat-6-title">
        <div class="feat-icon-wrap feat-icon-green" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7 10l2.5 2.5L14 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M10 3a7 7 0 1 0 0 14A7 7 0 0 0 10 3z" stroke="currentColor" stroke-width="1.4"/>
          </svg>
        </div>
        <h3 id="feat-6-title" class="display-sm feat-title">No account needed.</h3>
        <p class="body-md feat-desc">
          No sign-up, no email, no OAuth, no cookies tracking you across sessions.
          Open the page, paste a URL, download the video. That's the entire product.
        </p>
        <div class="feat-tag">
          <span class="caption-mono" style="color: var(--color-mute);">open · free · instant</span>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .features-band {
    background-color: var(--color-canvas-soft);
    padding: var(--sp-5xl) var(--sp-lg);
  }

  .features-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--sp-sm);
    margin-bottom: var(--sp-3xl);
  }

  .features-title {
    margin: 0;
    max-width: 560px;
  }

  .features-subtitle {
    margin: 0;
    max-width: 540px;
    color: var(--color-body);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-lg);
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
  }

  /* Icon wrappers */
  .feat-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: var(--rounded-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .feat-icon-blue   { background-color: #dbeafe; color: #1d4ed8; }
  .feat-icon-violet { background-color: #ede9fe; color: #7c3aed; }
  .feat-icon-pink   { background-color: #fce7f3; color: #be185d; }
  .feat-icon-teal   { background-color: #ccfbf1; color: #0d9488; }
  .feat-icon-amber  { background-color: #fef3c7; color: #d97706; }
  .feat-icon-green  { background-color: #dcfce7; color: #16a34a; }

  .feat-title {
    margin: 0;
    color: var(--color-ink);
  }

  .feat-desc {
    margin: 0;
    color: var(--color-body);
    flex: 1;
  }

  .feat-tag {
    margin-top: auto;
  }

  .kbd-inline {
    display: inline-flex;
    align-items: center;
    background-color: var(--color-canvas-soft-2);
    border: 1px solid var(--color-hairline);
    border-bottom-width: 2px;
    border-radius: 4px;
    padding: 0 5px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-body);
  }

  .code-inline {
    font-family: var(--font-mono);
    font-size: 12px;
    background-color: var(--color-canvas-soft-2);
    padding: 1px 5px;
    border-radius: 3px;
    color: var(--color-body);
  }

  @media (max-width: 960px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .features-grid { grid-template-columns: 1fr; }
    .features-band { padding: var(--sp-4xl) var(--sp-md); }
    .features-header { margin-bottom: var(--sp-xl); }
  }

  @media (max-width: 480px) {
    .features-band { padding: var(--sp-3xl) var(--sp-sm); }
    .feature-card { padding: var(--sp-md); }
    .feat-desc { font-size: 14px; line-height: 22px; }
  }

  /* Dark mode icon tints */
  :root[data-theme="dark"] .feat-icon-blue   { background-color: rgba(29, 78, 216, 0.2); color: #60a5fa; }
  :root[data-theme="dark"] .feat-icon-violet { background-color: rgba(124, 58, 237, 0.2); color: #a78bfa; }
  :root[data-theme="dark"] .feat-icon-pink   { background-color: rgba(190, 24, 93, 0.2); color: #f472b6; }
  :root[data-theme="dark"] .feat-icon-teal   { background-color: rgba(13, 148, 136, 0.2); color: #2dd4bf; }
  :root[data-theme="dark"] .feat-icon-amber  { background-color: rgba(217, 119, 6, 0.2); color: #fbbf24; }
  :root[data-theme="dark"] .feat-icon-green  { background-color: rgba(22, 163, 74, 0.2); color: #4ade80; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .feat-icon-blue   { background-color: rgba(29, 78, 216, 0.2); color: #60a5fa; }
    :root:not([data-theme="light"]) .feat-icon-violet { background-color: rgba(124, 58, 237, 0.2); color: #a78bfa; }
    :root:not([data-theme="light"]) .feat-icon-pink   { background-color: rgba(190, 24, 93, 0.2); color: #f472b6; }
    :root:not([data-theme="light"]) .feat-icon-teal   { background-color: rgba(13, 148, 136, 0.2); color: #2dd4bf; }
    :root:not([data-theme="light"]) .feat-icon-amber  { background-color: rgba(217, 119, 6, 0.2); color: #fbbf24; }
    :root:not([data-theme="light"]) .feat-icon-green  { background-color: rgba(22, 163, 74, 0.2); color: #4ade80; }
  }
</style>

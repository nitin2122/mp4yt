---
// Footer — Brutalist style with structural borders, mono typography
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.png';

const year = new Date().getFullYear();
---

<footer class="site-footer" aria-labelledby="footer-label">
  <div class="page-container footer-inner">
    <!-- Col 1: Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="mp4yt home">
        <div class="footer-logo-mark">
          <Image src={logoImage} width={20} height={20} alt="mp4yt logo" />
        </div>
        <span class="footer-logo-text">MP4YT</span>
      </a>
      <p class="body-sm footer-tagline">
        The fastest way to download videos from Instagram, TikTok and 1000+ platforms.
        Zero storage. Zero tracking.
      </p>
      <div class="footer-legal-note" style="margin-top: var(--sp-sm);">
        FOR PERSONAL, NON-COMMERCIAL USE ONLY.
      </div>
    </div>

    <!-- Col 2: Product -->
    <div class="footer-col">
      <h3 class="eyebrow footer-col-head" id="footer-label">PRODUCT</h3>
      <ul class="footer-links" role="list">
        <li><a href="/yt-downloader/" class="footer-link">YT Downloader</a></li>
        <li><a href="#features" class="footer-link">Features</a></li>
        <li><a href="#how-it-works" class="footer-link">How it works</a></li>
        <li><a href="#platforms" class="footer-link">Platforms</a></li>
        <li><a href="#faq" class="footer-link">FAQ</a></li>
      </ul>
    </div>

    <!-- Col 3: Platforms -->
    <div class="footer-col">
      <h3 class="eyebrow footer-col-head">PLATFORMS</h3>
      <ul class="footer-links" role="list">
        <li><a href="/instagram/" class="footer-link">Instagram</a></li>
        <li><a href="/tiktok/" class="footer-link">TikTok</a></li>
        <li><a href="/twitter/" class="footer-link">Twitter/X</a></li>
        <li><a href="/facebook/" class="footer-link">Facebook</a></li>
        <li><a href="/reddit/" class="footer-link">Reddit</a></li>
        <li><a href="/vimeo/" class="footer-link">Vimeo</a></li>
        <li><a href="/twitch/" class="footer-link">Twitch</a></li>
        <li><a href="/soundcloud/" class="footer-link">SoundCloud</a></li>
        <li><a href="/dailymotion/" class="footer-link">Dailymotion</a></li>
        <li><a href="/pinterest/" class="footer-link">Pinterest</a></li>
        <li><a href="/linkedin/" class="footer-link">LinkedIn</a></li>
      </ul>
    </div>

    <!-- Col 4: Legal & Resources -->
    <div class="footer-col">
      <h3 class="eyebrow footer-col-head">LEGAL</h3>
      <ul class="footer-links" role="list">
        <li><a href="/privacy-policy/" class="footer-link">Privacy Policy</a></li>
        <li><a href="/terms-and-conditions/" class="footer-link">Terms & Conditions</a></li>
        <li><a href="/dmca/" class="footer-link">DMCA</a></li>
        <li><a href="/about-us/" class="footer-link">About Us</a></li>
        <li><a href="/contact-us/" class="footer-link">Contact Us</a></li>
        <li>
          <a
            href="https://github.com/wukko/cobalt"
            class="footer-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            Cobalt on GitHub ↗
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="page-container footer-bottom-inner">
      <div class="footer-bottom-left">
        <span class="data-mono footer-copyright">©{year}_CORE_SYSTEM_v1.0</span>
        <span class="footer-sep" aria-hidden="true">|</span>
        <span class="footer-status">
          <span class="status-dot-footer"></span>
          API_STATUS: NOMINAL
        </span>
      </div>
      <div class="footer-bottom-right">
        <a href="https://github.com/wukko/cobalt" class="footer-link-bottom" target="_blank" rel="noopener">GITHUB</a>
        <a href="/terms-and-conditions/" class="footer-link-bottom">TERMS</a>
        <a href="/privacy-policy/" class="footer-link-bottom">PRIVACY</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-canvas);
    border-top: var(--border);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--sp-4xl);
    padding-top: var(--sp-4xl);
    padding-bottom: var(--sp-4xl);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-xs);
    text-decoration: none;
  }

  .footer-logo-text {
    font-family: var(--font-headline);
    font-size: 18px;
    font-weight: 800;
    color: var(--color-ink);
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .footer-tagline {
    margin: 0;
    color: var(--color-body);
    max-width: 280px;
  }

  .footer-legal-note {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-mute);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
  }

  .footer-col-head {
    margin: 0;
    color: var(--color-ink);
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 400;
    color: var(--color-body);
    text-decoration: none;
    line-height: 1.5;
    transition: all 0.1s ease;
  }

  .footer-link:hover {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: var(--border);
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--sp-md);
    padding-bottom: var(--sp-md);
    flex-wrap: wrap;
    gap: var(--sp-sm);
  }

  .footer-bottom-left {
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-ink);
  }

  .footer-sep {
    opacity: 0.3;
  }

  .footer-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-mute);
    letter-spacing: 0.05em;
  }

  .status-dot-footer {
    width: 6px;
    height: 6px;
    background-color: #28c840;
    display: inline-block;
    animation: statusPulse 2s ease-in-out infinite;
  }

  @keyframes statusPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .footer-bottom-right {
    display: flex;
    gap: var(--sp-md);
  }

  .footer-link-bottom {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-body);
    text-decoration: none;
    transition: all 0.1s ease;
  }

  .footer-link-bottom:hover {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-thickness: 2px;
  }

  @media (max-width: 960px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-xl);
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-lg);
      padding-top: var(--sp-xl);
      padding-bottom: var(--sp-xl);
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--sp-xl);
      padding-left: var(--sp-sm);
      padding-right: var(--sp-sm);
    }
    .footer-link {
      font-size: 12px;
    }
    .footer-bottom-inner {
      padding-left: var(--sp-sm);
      padding-right: var(--sp-sm);
      padding-bottom: calc(var(--sp-md) + env(safe-area-inset-bottom, 0px));
    }
  }
</style>

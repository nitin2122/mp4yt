---
// PlatformHero.astro — Reusable hero for platform-specific landing pages
// Props: platform name, emoji, color, description, example URL placeholder
import PlatformSwitcher from './PlatformSwitcher.astro';

interface Props {
  platform: string;
  emoji: string;
  accentColor: string;
  tagline: string;
  description: string;
  placeholder: string;
  features: string[];
}

const { platform, emoji, accentColor, tagline, description, placeholder, features } = Astro.props;
---

<section id="hero" class="platform-hero" aria-labelledby="platform-headline">
  <div class="mesh-bg" aria-hidden="true"></div>
  <div class="noise-overlay" aria-hidden="true"></div>

  <div class="page-container platform-hero-content">
    <!-- Eyebrow -->
    <div class="platform-eyebrow">
      <span class="platform-badge" style={`--accent: ${accentColor}`}>
        <span class="platform-emoji" aria-hidden="true">{emoji}</span>
        {platform} Downloader
      </span>
    </div>

    <!-- Headline -->
    <h1 id="platform-headline" class="display-xl platform-headline">
      {tagline}
    </h1>

    <p class="body-lg platform-subhead">{description}</p>

    <!-- URL Input Form -->
    <div class="hero-input-wrapper">
      <PlatformSwitcher currentPlatform={platform} />
      <form id="extract-form" class="input-row" aria-label={`${platform} URL extractor`} novalidate>
        <div class="input-group">
          <span class="input-icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M6 3.5H4.5A2.5 2.5 0 0 0 2 6v.5M10 3.5h1.5A2.5 2.5 0 0 1 14 6v.5M6 12.5H4.5A2.5 2.5 0 0 1 2 10v-.5M10 12.5h1.5A2.5 2.5 0 0 0 14 10v-.5M6 8h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
          </span>
          <input
            id="hero-input"
            type="url"
            class="hero-url-input"
            placeholder={placeholder}
            aria-label={`${platform} video URL`}
            autocomplete="off"
            spellcheck="false"
            enterkeyhint="go"
          />
          <button id="extract-btn" type="submit" class="btn-primary extract-btn" aria-label="Extract video">
            <svg id="extract-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M7 1v8M4 6l3 3 3-3M2 11h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <svg id="extract-spinner" class="animate-spin hidden" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="5" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
              <path d="M7 2a5 5 0 0 1 5 5" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span id="extract-btn-label">Extract</span>
          </button>
        </div>
        <div id="progress-bar" class="progress-bar-track hidden" role="progressbar" aria-label="Loading…">
          <div class="progress-bar-fill"></div>
        </div>
        <div id="error-msg" class="error-msg hidden" role="alert" aria-live="assertive"></div>
      </form>
      <p class="paste-hint body-sm" aria-live="polite" id="paste-hint">
        <kbd class="kbd">Ctrl+V</kbd> to paste — we'll auto-detect
      </p>
    </div>

    <!-- Feature chips -->
    <div class="platform-features" role="list">
      {features.map(f => (
        <div class="feature-chip" role="listitem">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M1.5 6l3 3L10.5 2" stroke={accentColor} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {f}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Result Card (same as main page) -->
<div id="result-section" class="result-section hidden" aria-live="polite" aria-label="Video extraction result">
  <div class="page-container">
    <div id="result-card" class="result-card card-lg animate-fade-in-up">
      <div class="result-inner">
        <div class="result-media">
          <div class="thumbnail-wrapper">
            <img id="result-thumb" src="" alt="" class="result-thumb" loading="lazy" />
            <div class="thumb-overlay" aria-hidden="true">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <circle cx="20" cy="20" r="20" fill="rgba(0,0,0,0.5)"/>
                <path d="M16 13l14 7-14 7V13z" fill="white"/>
              </svg>
            </div>
          </div>
        </div>
        <div class="result-meta">
          <div class="result-header">
            <span class="eyebrow" id="result-platform">{platform}</span>
            <h2 id="result-title" class="display-sm result-title"></h2>
          </div>
          <div class="result-stats">
            <div class="stat-item">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <circle cx="7" cy="7" r="5" stroke="var(--color-mute)" stroke-width="1.3"/>
                <path d="M7 4.5V7l2 1.5" stroke="var(--color-mute)" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              <span id="result-duration" class="body-sm" style="color: var(--color-body);"></span>
            </div>
            <div class="stat-item">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2.5 9.5L7 4.5l4.5 5" stroke="var(--color-mute)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="body-sm" style="color: var(--color-body);">Best quality MP4</span>
            </div>
          </div>
          <!-- Advanced Quality / Resolution Dropdown Option Button -->
          <div class="result-resolutions">
            <span class="eyebrow">Select Resolution</span>
            <div class="quality-dropdown-container">
              <button id="quality-dropdown-trigger" class="quality-dropdown-trigger" aria-haspopup="listbox" aria-expanded="false" type="button">
                <span class="dropdown-trigger-icon">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="2" y="2" width="12" height="12" rx="2" stroke-width="1.5"/>
                    <path d="M5 8.5h6M5 11.5h6M5 5.5h6" stroke-linecap="round"/>
                  </svg>
                </span>
                <span id="quality-trigger-text">Select Quality</span>
                <span class="dropdown-chevron">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M3 4.5l3 3 3-3" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </button>
              <div id="quality-dropdown-menu" class="quality-dropdown-menu hidden" role="listbox">
                <!-- Dynamically populated options -->
              </div>
            </div>
          </div>

          <div class="result-filename">
            <span class="eyebrow">Filename</span>
            <code id="result-filename-display" class="code filename-code"></code>
          </div>

          <div class="result-actions">
            <a
              id="result-download-btn"
              href="#"
              class="btn-primary btn-primary-lg"
              rel="noopener noreferrer"
              download
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 2v8M5 7l3 3 3-3M2 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Download MP4
            </a>
            <button class="btn-secondary" id="copy-url-btn" aria-label="Copy direct URL">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="5" y="5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M11 5V4a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              Copy URL
            </button>
          </div>
          <details class="video-preview-toggle">
            <summary class="body-sm-strong preview-summary">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 3.5a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v7a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-7z" stroke="currentColor" stroke-width="1.2"/>
                <path d="M5.5 5.5L8.5 7l-3 1.5v-3z" fill="currentColor"/>
              </svg>
              Preview video in browser
            </summary>
            <div class="video-preview-wrapper">
              <video id="result-video" controls preload="metadata" class="result-video">
                Your browser does not support the video tag.
              </video>
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .platform-hero {
    position: relative;
    overflow: hidden;
    background-color: var(--color-canvas);
    padding: var(--sp-section) var(--sp-lg) var(--sp-5xl);
    min-height: 560px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .noise-overlay {
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.025'/%3E%3C/svg%3E");
    pointer-events: none; opacity: 0.4;
  }
  .platform-hero-content {
    position: relative; z-index: 2;
    display: flex; flex-direction: column;
    align-items: center; text-align: center;
    gap: var(--sp-lg);
  }
  .platform-eyebrow { display: flex; justify-content: center; }
  .platform-badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 12px; border-radius: 100px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    font-size: 13px; font-weight: 500; color: var(--color-ink);
  }
  .platform-emoji { font-size: 15px; }
  .platform-headline { margin: 0; max-width: 720px; color: var(--color-ink); }
  .platform-subhead { margin: 0; max-width: 540px; color: var(--color-body); }

  .hero-input-wrapper {
    width: 100%; max-width: 640px;
    display: flex; flex-direction: column;
    gap: var(--sp-sm); margin-top: var(--sp-xs);
  }
  .input-row { display: flex; flex-direction: column; gap: var(--sp-xs); }
  .input-group {
    display: flex; align-items: center;
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--rounded-md);
    overflow: hidden; box-shadow: var(--shadow-3);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .input-group:focus-within {
    border-color: var(--color-hairline-strong);
    box-shadow: var(--shadow-4), 0 0 0 3px rgba(0, 112, 243, 0.1);
  }
  .input-icon { display: flex; align-items: center; padding: 0 var(--sp-sm); color: var(--color-mute); flex-shrink: 0; }
  .hero-url-input {
    flex: 1; border: none; outline: none; background: transparent;
    font-family: var(--font-sans); font-size: 16px; color: var(--color-ink);
    padding: var(--sp-md) var(--sp-sm) var(--sp-md) 0; min-width: 0;
  }
  .hero-url-input::placeholder { color: var(--color-mute); }
  .extract-btn {
    border-radius: 0 var(--rounded-md) var(--rounded-md) 0 !important;
    height: 54px; padding: 0 var(--sp-lg); font-size: 15px; flex-shrink: 0; gap: var(--sp-xs);
  }
  .progress-bar-track { margin-top: 4px; }
  .error-msg {
    padding: var(--sp-xs) var(--sp-sm);
    background-color: var(--color-error-soft);
    border: 1px solid var(--color-error-border, #f9c8c8); border-radius: var(--rounded-sm);
    color: var(--color-error-deep); font-size: 14px; line-height: 20px;
  }
  .paste-hint { margin: 0; color: var(--color-mute); text-align: center; }
  .kbd {
    display: inline-flex; align-items: center;
    background-color: var(--color-canvas-soft-2);
    border: 1px solid var(--color-hairline); border-bottom-width: 2px;
    border-radius: 4px; padding: 0 5px;
    font-family: var(--font-mono); font-size: 11px; color: var(--color-body);
  }

  .platform-features {
    display: flex; flex-wrap: wrap; gap: var(--sp-xs);
    justify-content: center; margin-top: var(--sp-xs);
  }
  .feature-chip {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 10px; border-radius: 100px;
    background-color: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    font-size: 12px; color: var(--color-body);
  }

  /* Result section (mirrors Hero.astro) */
  .result-section {
    background-color: var(--color-canvas-soft);
    padding: var(--sp-4xl) 0;
    border-top: 1px solid var(--color-hairline);
    border-bottom: 1px solid var(--color-hairline);
  }
  .result-card { overflow: hidden; }
  .result-inner { display: grid; grid-template-columns: 280px 1fr; gap: var(--sp-xl); align-items: start; }
  .result-media { position: relative; }
  .thumbnail-wrapper {
    position: relative; border-radius: var(--rounded-md); overflow: hidden;
    aspect-ratio: 16/9; background-color: var(--color-canvas-soft-2); box-shadow: var(--shadow-3);
  }
  .result-thumb { width: 100%; height: 100%; object-fit: cover; display: block; }
  .thumb-overlay {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,0.1); opacity: 0; transition: opacity 0.2s ease;
  }
  .thumbnail-wrapper:hover .thumb-overlay { opacity: 1; }
  .result-meta { display: flex; flex-direction: column; gap: var(--sp-lg); }
  .result-header { display: flex; flex-direction: column; gap: var(--sp-xs); }
  .result-title {
    margin: 0; color: var(--color-ink);
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .result-stats { display: flex; align-items: center; gap: var(--sp-md); flex-wrap: wrap; }
  .stat-item { display: flex; align-items: center; gap: 6px; }
  .result-filename { display: flex; flex-direction: column; gap: 6px; }
  .filename-code {
    font-family: var(--font-mono); font-size: 12px; color: var(--color-body);
    background-color: var(--color-canvas-soft-2); padding: var(--sp-xs) var(--sp-sm);
    border-radius: var(--rounded-sm); word-break: break-all; display: block;
  }
  .result-actions { display: flex; align-items: center; gap: var(--sp-sm); flex-wrap: wrap; }
  .video-preview-toggle { border: none; }
  .preview-summary {
    display: flex; align-items: center; gap: var(--sp-xs);
    cursor: pointer; color: var(--color-link); list-style: none;
    padding: var(--sp-xs) 0; transition: color 0.15s ease;
  }
  .preview-summary:hover { color: var(--color-link-deep); }
  .preview-summary::-webkit-details-marker { display: none; }
  .video-preview-wrapper {
    margin-top: var(--sp-sm); border-radius: var(--rounded-md);
    overflow: hidden; background: #000; box-shadow: var(--shadow-3);
  }
  .result-video { width: 100%; max-height: 360px; display: block; }
  .result-resolutions {
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
    margin-top: var(--sp-xs);
  }

  /* Quality select dropdown */
  .quality-dropdown-container {
    position: relative;
    width: 100%;
  }

  .quality-dropdown-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 48px;
    padding: 0 var(--sp-md);
    border-radius: var(--rounded-md);
    background-color: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    color: var(--color-ink);
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.15s ease;
    box-shadow: var(--shadow-2);
  }

  .quality-dropdown-trigger:hover,
  .quality-dropdown-trigger.active {
    border-color: var(--color-hairline-strong);
    background-color: var(--color-canvas-soft);
  }

  .dropdown-trigger-icon {
    display: flex;
    align-items: center;
    color: var(--color-mute);
  }

  #quality-trigger-text {
    flex: 1;
    text-align: left;
    margin-left: var(--sp-sm);
  }

  .dropdown-chevron {
    display: flex;
    align-items: center;
    color: var(--color-mute);
    transition: transform 0.2s ease;
  }

  .quality-dropdown-trigger.active .dropdown-chevron {
    transform: rotate(180deg);
  }

  .quality-dropdown-menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    z-index: 100;
    max-height: 280px;
    overflow-y: auto;
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--rounded-md);
    box-shadow: var(--shadow-4);
    display: flex;
    flex-direction: column;
    padding: 6px;
    gap: 2px;
  }

  /* Support dark-theme style glassmorphism */
  @media (prefers-color-scheme: dark) {
    .quality-dropdown-menu {
      background: rgba(17, 17, 17, 0.85);
      backdrop-filter: blur(12px);
    }
  }

  :root[data-theme="dark"] .quality-dropdown-menu {
    background: rgba(17, 17, 17, 0.85);
    backdrop-filter: blur(12px);
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-xs) var(--sp-sm);
    border-radius: var(--rounded-sm);
    border: none;
    background: transparent;
    color: var(--color-ink);
    cursor: pointer;
    text-align: left;
    width: 100%;
    font-family: var(--font-sans);
    transition: background-color 0.1s ease;
  }

  .dropdown-item:hover {
    background-color: var(--color-canvas-soft-2);
  }

  .dropdown-item.active {
    background-color: var(--color-link-bg-soft);
    color: var(--color-link-deep);
    font-weight: 500;
  }

  .opt-info {
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
  }

  .opt-res {
    font-size: 14px;
    font-weight: 500;
  }

  .opt-badge {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    padding: 1px 5px;
    border-radius: 3px;
    background-color: var(--color-canvas-soft-2);
    border: 1px solid var(--color-hairline-strong);
    color: var(--color-body);
    text-transform: uppercase;
  }

  .dropdown-item.active .opt-badge {
    background-color: var(--color-link-deep);
    color: #ffffff;
    border-color: transparent;
  }

  .opt-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
  }

  .opt-size {
    font-size: 12px;
    color: var(--color-mute);
  }

  .dropdown-item.active .opt-size {
    color: var(--color-link-deep);
    opacity: 0.8;
  }

  .opt-audio {
    display: inline-flex;
    align-items: center;
  }

  .opt-audio.has-audio {
    color: #10b981;
  }

  .opt-audio.no-audio {
    color: var(--color-mute);
  }

  .dropdown-item.active .opt-audio.has-audio {
    color: var(--color-link-deep);
  }

  .hidden { display: none !important; }

  @media (max-width: 768px) {
    .platform-hero { padding: var(--sp-5xl) var(--sp-md) var(--sp-4xl); min-height: auto; }
    .result-inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .extract-btn { padding: 0 var(--sp-md); }
    .result-actions { flex-direction: column; }
    .result-actions .btn-primary, .result-actions .btn-secondary { width: 100%; justify-content: center; }
  }
</style>

<script>
  const form = document.getElementById('extract-form') as HTMLFormElement;
  const input = document.getElementById('hero-input') as HTMLInputElement;
  const extractBtn = document.getElementById('extract-btn') as HTMLButtonElement;
  const extractIcon = document.getElementById('extract-icon') as SVGElement;
  const extractSpinner = document.getElementById('extract-spinner') as SVGElement;
  const extractBtnLabel = document.getElementById('extract-btn-label') as HTMLSpanElement;
  const progressBar = document.getElementById('progress-bar') as HTMLDivElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const resultSection = document.getElementById('result-section') as HTMLDivElement;
  const resultThumb = document.getElementById('result-thumb') as HTMLImageElement;
  const resultTitle = document.getElementById('result-title') as HTMLHeadingElement;
  const resultDuration = document.getElementById('result-duration') as HTMLSpanElement;
  const resultFilename = document.getElementById('result-filename-display') as HTMLElement;
  const resultDownloadBtn = document.getElementById('result-download-btn') as HTMLAnchorElement;
  const copyUrlBtn = document.getElementById('copy-url-btn') as HTMLButtonElement;
  const resultVideo = document.getElementById('result-video') as HTMLVideoElement;
  const triggerBtn = document.getElementById('quality-dropdown-trigger') as HTMLButtonElement;
  const dropdownMenu = document.getElementById('quality-dropdown-menu') as HTMLDivElement;
  const triggerText = document.getElementById('quality-trigger-text') as HTMLSpanElement;

  let currentStreamUrl = '';
  let currentFilename = 'video.mp4';

  document.addEventListener('paste', (e: ClipboardEvent) => {
    const text = e.clipboardData?.getData('text/plain')?.trim() ?? '';
    if (text && isValidUrl(text) && document.activeElement !== input) {
      input.value = text;
      extractVideo(text);
    }
  });

  form.addEventListener('submit', (e: Event) => {
    e.preventDefault();
    const url = input.value.trim();
    if (!url) return;
    if (!isValidUrl(url)) {
      showError('Please paste a valid video URL.');
      return;
    }
    extractVideo(url);
  });

  function isValidUrl(url: string): boolean {
    try {
      const u = new URL(url);
      return u.protocol === 'http:' || u.protocol === 'https:';
    } catch { return false; }
  }

  function setLoading(loading: boolean) {
    extractBtn.disabled = loading;
    extractIcon.classList.toggle('hidden', loading);
    extractSpinner.classList.toggle('hidden', !loading);
    extractBtnLabel.textContent = loading ? 'Extracting…' : 'Extract';
    progressBar.classList.toggle('hidden', !loading);
    errorMsg.classList.add('hidden');
  }

  function showError(msg: string) {
    errorMsg.textContent = msg;
    errorMsg.classList.remove('hidden');
    resultSection.classList.add('hidden');
  }

  function formatDuration(seconds: number): string {
    if (!seconds || isNaN(seconds)) return 'Unknown duration';
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    const s = Math.floor(seconds % 60);
    if (h > 0) return `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    return `${m}:${String(s).padStart(2,'0')}`;
  }

  function formatBytes(bytes: number, decimals = 1): string {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
  }

  function sanitizeFilename(title: string): string {
    if (!title || typeof title !== 'string') return 'video';
    return title
      .toLowerCase()
      .replace(/[^a-z0-9\s\-_]/g, '')
      .trim()
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .slice(0, 120) || 'video';
  }

  function getFilenameWithRes(title: string, res: string, ext: string): string {
    const cleanRes = res.toLowerCase().replace(/[^a-z0-9]/g, '');
    const sanitized = sanitizeFilename(title);
    return `${sanitized}-${cleanRes}.${ext}`;
  }

  async function extractVideo(url: string) {
    setLoading(true);
    try {
      const resp = await fetch(`/api/extract?url=${encodeURIComponent(url)}`);
      const data = await resp.json();
      if (!resp.ok) {
        showError(data.error ?? 'Failed to extract video. Please check the URL and try again.');
        return;
      }
      resultTitle.textContent = data.title ?? 'Untitled video';
      resultDuration.textContent = formatDuration(data.duration);
      currentFilename = data.filename ?? 'video.mp4';
      resultFilename.textContent = currentFilename;
      resultThumb.src = data.thumbnail ?? '';
      resultThumb.alt = data.title ?? 'Video thumbnail';
      currentStreamUrl = data.url;
      const downloadUrl = `/download-stream?url=${encodeURIComponent(data.url)}&filename=${encodeURIComponent(currentFilename)}`;
      resultDownloadBtn.href = downloadUrl;
      resultDownloadBtn.setAttribute('download', currentFilename);
      resultVideo.src = currentStreamUrl;

      // Populate resolution options dropdown
      dropdownMenu.innerHTML = '';
      if (Array.isArray(data.formats) && data.formats.length > 0) {
        let selectedFormat = data.formats[0];

        const updateSelectedFormat = (fmt: any) => {
          selectedFormat = fmt;
          const label = fmt.resolution;
          const sizeStr = fmt.filesize ? formatBytes(fmt.filesize) : 'Unknown size';
          triggerText.textContent = `${label} (${fmt.ext} · ${sizeStr})`;
          
          currentStreamUrl = fmt.url;
          const specificFilename = getFilenameWithRes(data.title || 'video', fmt.resolution, fmt.ext);
          let rowDownloadUrl = `/download-stream?url=${encodeURIComponent(fmt.url)}&filename=${encodeURIComponent(specificFilename)}`;
          if (fmt.audio_url) {
            rowDownloadUrl += `&audioUrl=${encodeURIComponent(fmt.audio_url)}`;
          }
          resultDownloadBtn.href = rowDownloadUrl;
          resultDownloadBtn.setAttribute('download', specificFilename);
          currentFilename = specificFilename;
          resultFilename.textContent = specificFilename;

          // Video preview uses raw stream URL directly (plays inline)
          resultVideo.src = fmt.url;

          // Modify download button text
          resultDownloadBtn.innerHTML = `
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M8 2v8M5 7l3 3 3-3M2 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Download ${fmt.resolution}
          `;

          // Mark active item in dropdown
          const items = dropdownMenu.querySelectorAll('.dropdown-item');
          items.forEach((item: any) => {
            const itemRes = item.getAttribute('data-res');
            if (itemRes === fmt.resolution) {
              item.classList.add('active');
              item.setAttribute('aria-selected', 'true');
            } else {
              item.classList.remove('active');
              item.setAttribute('aria-selected', 'false');
            }
          });
        };

        data.formats.forEach((fmt: any) => {
          const item = document.createElement('button');
          item.className = 'dropdown-item';
          item.type = 'button';
          item.role = 'option';
          item.setAttribute('data-res', fmt.resolution);
          item.setAttribute('data-ext', fmt.ext);

          const sizeLabel = fmt.filesize ? formatBytes(fmt.filesize) : 'Unknown size';
          const audioIcon = fmt.has_audio
            ? `<span class="opt-audio has-audio" title="Contains Audio"><svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" style="display:inline-block;vertical-align:middle;margin-right:4px;"><path d="M8 2a.75.75 0 01.19.46v10.58a.75.75 0 01-1.28.53L3.69 10.5H1.75A.75.75 0 011 9.75V6.25A.75.75 0 011.75 5.5h1.94l3.22-3.28A.75.75 0 018 2zm3.3 3.2a.75.75 0 111.1 1.02 3.5 3.5 0 010 4.56.75.75 0 11-1.1 1.02 5 5 0 000-6.6zM13.8 2.7a.75.75 0 111.1 1.02 8 8 0 010 9.56.75.75 0 11-1.1 1.02 9.5 9.5 0 000-11.6z"/></svg>Video + Audio</span>`
            : `<span class="opt-audio no-audio" title="No Audio (Muted)"><svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" style="display:inline-block;vertical-align:middle;margin-right:4px;"><path d="M6.5 1.75a.75.75 0 01.19.46v11.58a.75.75 0 01-1.28.53L2.19 11H.75A.75.75 0 010 10.25V5.75A.75.75 0 01.75 5h1.44l3.22-3.28a.75.75 0 01.59-.22zM12.44 8l1.78-1.78a.75.75 0 00-1.06-1.06L11.38 6.94l-1.78-1.78a.75.75 0 00-1.06 1.06L10.32 8l-1.78 1.78a.75.75 0 001.06 1.06l1.78-1.78 1.78 1.78a.75.75 0 001.06-1.06L12.44 8z"/></svg>Video Only</span>`;

          item.innerHTML = `
            <div class="opt-info">
              <span class="opt-res">${fmt.resolution}</span>
              <span class="opt-badge">${fmt.ext}</span>
            </div>
            <div class="opt-meta">
              <span class="opt-size">${sizeLabel}</span>
              ${audioIcon}
            </div>
          `;

          item.addEventListener('click', () => {
            updateSelectedFormat(fmt);
            dropdownMenu.classList.add('hidden');
            triggerBtn.classList.remove('active');
            triggerBtn.setAttribute('aria-expanded', 'false');
          });

          dropdownMenu.appendChild(item);
        });

        // Initialize with default selection
        updateSelectedFormat(selectedFormat);
      }

      resultSection.classList.remove('hidden');
      resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch {
      showError('Network error — please try again.');
    } finally {
      setLoading(false);
    }
  }

  // Toggle quality select dropdown
  if (triggerBtn && dropdownMenu) {
    triggerBtn.addEventListener('click', (e: Event) => {
      e.stopPropagation();
      const isHidden = dropdownMenu.classList.contains('hidden');
      dropdownMenu.classList.toggle('hidden', !isHidden);
      triggerBtn.classList.toggle('active', isHidden);
      triggerBtn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
    });

    // Close when clicking outside
    document.addEventListener('click', (e: Event) => {
      if (!triggerBtn.contains(e.target as Node) && !dropdownMenu.contains(e.target as Node)) {
        dropdownMenu.classList.add('hidden');
        triggerBtn.classList.remove('active');
        triggerBtn.setAttribute('aria-expanded', 'false');
      }
    });
  }

  // Native streaming download button — triggers Service Worker interception or direct browser proxy stream
  resultDownloadBtn.addEventListener('click', (e: Event) => {
    e.preventDefault();
    const downloadUrl = resultDownloadBtn.href;
    if (!downloadUrl || downloadUrl === '#') return;

    // Trigger download natively
    window.location.href = downloadUrl;

    // Provide immediate visual feedback on the button
    const origHTML = resultDownloadBtn.innerHTML;
    resultDownloadBtn.innerHTML = `
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" style="display:inline-block;vertical-align:middle;margin-right:6px;">
        <path d="M2 8l4 4L14 3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Download Started
    `;
    (resultDownloadBtn as any).style.pointerEvents = 'none';

    setTimeout(() => {
      resultDownloadBtn.innerHTML = origHTML;
      (resultDownloadBtn as any).style.pointerEvents = '';
    }, 4000);
  });

  copyUrlBtn.addEventListener('click', async () => {
    if (!currentStreamUrl) return;
    try {
      await navigator.clipboard.writeText(currentStreamUrl);
      const prev = copyUrlBtn.innerHTML;
      copyUrlBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4L14 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> Copied!`;
      setTimeout(() => { copyUrlBtn.innerHTML = prev; }, 2000);
    } catch { /* fallback */ }
  });
</script>

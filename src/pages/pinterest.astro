---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
const pinterestFaqs = [
  {
    q: "How do I download videos from Pinterest?",
    a: "Open the Pinterest video pin, tap the share icon, copy the link, paste it into our Pinterest video downloader, click Extract, and save the MP4 video directly."
  },
  {
    q: "Does the Pinterest downloader support short links (pin.it)?",
    a: "Yes, our system automatically resolves short pin.it sharing links and extracts the original Pinterest video pin content."
  },
  {
    q: "Can I download images and GIFs from Pinterest?",
    a: "Yes. While optimized for video pins, our Pinterest downloader also lets you save high-quality images and loopable pin GIFs as MP4 files."
  }
];
---

<Layout
  title="Pinterest Video Downloader - Save Videos as MP4 | mp4yt"
  description="Download Pinterest videos in high quality MP4 instantly. Paste the Pinterest pin URL — no login, no storage, no limits."
  canonicalUrl="https://mp4yt.com/pinterest/"
  keywords="pinterest video downloader, download pinterest videos, save pinterest video, pinterest pin downloader, download pinterest mp4, pinterest link downloader, pinterest video download online, pinterest video saver, download video from pinterest, pinterest downloader free, pinterest video downloader hd, pinterest downloader online, pinterest to mp4, download pinterest idea pin, pinterest gif downloader, pinterest image downloader, pinterest downloader iphone, pinterest video downloader android, best pinterest video downloader, download pin video, pinterest video download 2026, save pinterest pin video, pinterest video converter, pinterest reel downloader, download pinterest video without app, pin.it downloader, pinterest short link downloader"
>
  <Navbar />
  <main id="main-content">
    <PlatformHero
      platform="Pinterest"
      emoji="📌"
      accentColor="#E60023"
      tagline="Pinterest Downloader"
      description="Just Paste and Play."
      placeholder="https://www.pinterest.com/pin/..."
      features={[
        "Pinterest video pins",
        "No login required",
        "Direct CDN download",
        "Zero server storage",
        "Mobile friendly",
      ]}
    />

    <section class="seo-section page-container">
      <div class="seo-grid">
        <div class="seo-block">
          <h2 class="display-sm">How to download Pinterest videos</h2>
          <ol class="seo-steps">
            <li>Open Pinterest and open the video pin you want to save.</li>
            <li>Click the share icon and select <strong>Copy Link</strong>.</li>
            <li>Paste the URL in the downloader box above.</li>
            <li>Click <strong>Extract</strong>, review preview, and select <strong>Download MP4</strong>.</li>
          </ol>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Supported formats</h2>
          <ul class="seo-list">
            <li>Standard Pinterest video pins (pinterest.com/pin/...)</li>
            <li>Short link / share URLs (pin.it/...)</li>
            <li>High resolution MP4 downloads</li>
            <li>Direct fast CDNs</li>
          </ul>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Disclaimer</h2>
          <ul class="seo-list">
            <li>Private boards and pins are not supported</li>
            <li>Personal archival use only</li>
            <li>Zero analytics, no tracking pixels</li>
            <li>Bypass browser restrictions with our proxy</li>
          </ul>
        </div>
      </div>
    </section>

    <FAQ faqs={pinterestFaqs} />
  </main>
  <Footer />
</Layout>

<style>
  .seo-section { padding: var(--sp-4xl) var(--sp-lg); }
  .seo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
  .seo-block { display: flex; flex-direction: column; gap: var(--sp-md); }
  .seo-block h2 { margin: 0; color: var(--color-ink); }
  .seo-steps, .seo-list {
    margin: 0; padding-left: var(--sp-lg);
    display: flex; flex-direction: column; gap: var(--sp-xs);
    color: var(--color-body); font-size: 14px; line-height: 1.7;
  }
</style>

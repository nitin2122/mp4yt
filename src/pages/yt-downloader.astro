---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';

// YT-specific FAQs for this landing page
const ytFaqs = [
  {
    q: "What is a YT downloader?",
    a: "A YT downloader is a tool that lets you download videos from YouTube (YT) directly to your device. mp4yt is the best free yt downloader online — just paste any YouTube video URL, click Extract, and save your video as MP4 in up to 4K quality or convert to MP3. No app or sign-up needed."
  },
  {
    q: "How do I download YT videos with mp4yt?",
    a: "To download yt videos: 1) Copy the YouTube video URL from your browser or app. 2) Visit mp4yt.com/yt-downloader. 3) Paste the URL into the extraction bar above. 4) Click 'Extract' and wait a few seconds. 5) Select your quality (up to 4K) or choose MP3. 6) Click the download button. Done!"
  },
  {
    q: "Is mp4yt the best YT video downloader?",
    a: "mp4yt is widely considered the best yt video downloader for 2026. It's completely free, works in any browser, requires no installation, supports resolutions up to 4K Ultra HD, offers yt to mp3 conversion, and works on every device — iPhone, Android, PC, Mac, and Linux."
  },
  {
    q: "Can I use this YT downloader on my iPhone?",
    a: "Yes! This yt downloader works on iPhone, iPad, Android, and all devices. Since it's a web-based yt video downloader, just open mp4yt.com in Safari or Chrome, paste your YouTube link, extract, then tap the download button. On iOS, use 'Save to Files' to save the video."
  },
  {
    q: "Does this YT downloader convert videos to MP3?",
    a: "Absolutely. mp4yt works as both a yt to mp4 and yt to mp3 converter. After pasting your YouTube link, select the audio-only option to download the audio as a high-quality MP3 file. Perfect for music, podcasts, audiobooks, and lectures."
  },
  {
    q: "Is this YT video downloader free?",
    a: "Yes, mp4yt is a 100% free yt downloader — no subscription, no premium tier, no hidden costs, and no account required. We believe everyone should have access to a fast, reliable yt video downloader without paywalls."
  },
  {
    q: "Is this YT downloader safe and legal?",
    a: "mp4yt is completely safe — it's a web-based yt video downloader with no downloads, no malware, and no tracking. Downloading YT videos for personal, offline use of non-copyrighted content is generally permissible. Always respect content creators' rights."
  },
  {
    q: "What quality options does this YT downloader support?",
    a: "This yt video downloader supports every quality option available on YouTube: 360p, 480p, 720p HD, 1080p Full HD, 1440p 2K, and 2160p 4K Ultra HD. The exact options depend on what the original uploader provided. We deliver the direct CDN stream for maximum quality."
  }
];

// Generate FAQ JSON-LD Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": ytFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

// HowTo Schema for step-by-step
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Download YT Videos with mp4yt",
  "description": "Step-by-step guide to download YT videos using the mp4yt yt video downloader online tool.",
  "totalTime": "PT1M",
  "tool": {
    "@type": "HowToTool",
    "name": "mp4yt YT Downloader"
  },
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Copy the YouTube video URL",
      "text": "Open YouTube in your browser or app, find the video you want to download, and copy the URL from the address bar or share button."
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Paste the URL into mp4yt",
      "text": "Go to mp4yt.com/yt-downloader and paste the copied YouTube URL into the extraction bar."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Click Extract",
      "text": "Click the 'Extract' button and wait a few seconds for mp4yt to fetch the direct download links."
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Download your video or audio",
      "text": "Choose your preferred quality (up to 4K) or select MP3 for audio-only, then click the download button to save the file."
    }
  ]
};

// BreadcrumbList Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "mp4yt",
      "item": "https://mp4yt.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "YT Downloader",
      "item": "https://mp4yt.com/yt-downloader"
    }
  ]
};
---

<Layout
  title="YT Downloader — Free YT Video Downloader Online | mp4yt"
  description="Free YT downloader online. Download YT videos in 4K MP4 or convert YT to MP3. Best yt video downloader 2026 — works on iPhone, Android & PC. No app needed, no sign-up."
  canonicalUrl="https://mp4yt.com/yt-downloader"
  keywords="yt downloader, yt video downloader, download yt video, yt to mp4, yt to mp3, yt downloader online, yt downloader free, best yt downloader 2026, yt mp4 downloader, yt mp3 downloader, yt video downloader online free, download yt videos free, yt downloader no app, yt downloader for iphone, yt downloader for android, yt video downloader 4k, yt video downloader hd, youtube video downloader, youtube downloader, youtube to mp4, youtube to mp3, free yt downloader, yt downloader 2026, yt video download, download yt video online, best yt video downloader"
>
  <Navbar />
  <main id="main-content">
    <!-- JSON-LD Schemas -->
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <PlatformHero
      platform="YouTube"
      emoji="▶️"
      accentColor="#FF0000"
      tagline="YouTube Downloader"
      description="Just Paste and Play."

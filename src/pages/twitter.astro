---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Twitter/X Video Downloader — Download Twitter Videos as MP4 | mp4yt"
  description="Download Twitter and X (formerly Twitter) videos as MP4 instantly. Paste the tweet URL — no login, no watermark, no storage."
  canonicalUrl="https://mp4yt.com/twitter"
  keywords="twitter video downloader, x video downloader, download twitter videos, download x videos, save twitter video, save x video, twitter to mp4, x to mp4, twitter gif downloader"
>
  <Navbar />
  <main id="main-content">
    <PlatformHero
      platform="Twitter / X"
      emoji="🐦"
      accentColor="#1DA1F2"
      tagline="Download Twitter/X videos instantly."
      description="Paste any tweet or X post link containing a video and extract the direct MP4 stream in seconds. No login required."
      placeholder="https://twitter.com/user/status/... or https://x.com/..."
      features={[
        "Twitter & X supported",
        "GIF to MP4 conversion",
        "No Twitter login",
        "Zero storage",
        "Full HD quality",
      ]}
    />

    <section class="seo-section page-container">
      <div class="seo-grid">
        <div class="seo-block">
          <h2 class="display-sm">How to download Twitter/X videos</h2>
          <ol class="seo-steps">
            <li>Find the tweet on Twitter.com or X.com that contains the video.</li>
            <li>Click the <strong>Share</strong> icon → <strong>Copy link to Tweet</strong>.</li>
            <li>Paste the tweet URL in the field above.</li>
            <li>Click <strong>Extract</strong> then <strong>Download MP4</strong>.</li>
          </ol>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">What you can download</h2>
          <ul class="seo-list">
            <li>Twitter/X native videos</li>
            <li>Animated GIFs (converted to MP4)</li>
            <li>Videos from twitter.com and x.com</li>
            <li>Spaces recordings (when public)</li>
          </ul>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Tips</h2>
          <ul class="seo-list">
            <li>Both twitter.com and x.com links work</li>
            <li>Only public tweets can be downloaded</li>
            <li>Protected accounts are not supported</li>
            <li>For personal, non-commercial use only</li>
          </ul>
        </div>
      </div>
    </section>

    <FAQ />
  </main>
  <Footer />
</Layout>

<style>
  .seo-section { padding: var(--sp-4xl) var(--sp-lg); }
  .seo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
  .seo-block { display: flex; flex-direction: column; gap: var(--sp-md); }
  .seo-block h2 { margin: 0; color: var(--color-ink); }
  .seo-steps, .seo-list {
    margin: 0; padding-left: var(--sp-lg);
    display: flex; flex-direction: column; gap: var(--sp-xs);
    color: var(--color-body); font-size: 14px; line-height: 1.7;
  }
</style>

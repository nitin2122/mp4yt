---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
const twitterFaqs = [
  {
    q: "How can I download videos from Twitter (X)?",
    a: "Open the post containing the video on Twitter/X, copy the link to the tweet, paste it into our Twitter video downloader, click Extract, and download the MP4 file in HD quality."
  },
  {
    q: "Can I download animated GIFs from Twitter/X?",
    a: "Yes. Twitter/X displays GIFs in a custom video format. Our Twitter GIF downloader converts them back into standard loopable MP4 files for easy sharing and saving."
  },
  {
    q: "What is the maximum resolution for X video downloads?",
    a: "The downloader fetches the original quality uploaded by the tweet author, including Full HD (1080p) or HD (720p) depending on the source media."
  },
  {
    q: "Can I download video from private X accounts?",
    a: "No, our X video downloader only works on tweets from public profiles. Content from protected or private accounts cannot be accessed."
  }
];
---

<Layout
  title="Twitter/X Video Downloader - MP4 | mp4yt"
  description="Download Twitter/X videos as MP4 instantly. Paste the tweet URL — no login, no watermark, no storage needed."
  canonicalUrl="https://mp4yt.com/twitter/"
  keywords="twitter video downloader, x video downloader, download twitter videos, download x videos, save twitter video, save x video, twitter to mp4, x to mp4, twitter gif downloader, twitter video download online, download video from twitter, download video from x, twitter video saver, x video saver, twitter downloader free, x downloader free, twitter video download hd, x video download hd, twitter mp4 downloader, download twitter gif as mp4, tweet video downloader, download tweet video, twitter spaces downloader, x spaces downloader, twitter video downloader iphone, twitter video downloader android, twitter link downloader, x link downloader, download x post video, best twitter video downloader 2026, ssstwitter alternative, twitter video converter, save video from tweet"
>
  <Navbar />
  <main id="main-content">
    <PlatformHero
      platform="Twitter / X"
      emoji="🐦"
      accentColor="#1DA1F2"
      tagline="Twitter / X Downloader"
      description="Just Paste and Play."
      placeholder="https://twitter.com/user/status/... or https://x.com/..."
      features={[
        "Twitter & X supported",
        "GIF to MP4 conversion",
        "No Twitter login",
        "Zero storage",
        "Full HD quality",
      ]}
    />

    <section class="seo-section page-container">
      <div class="seo-grid">
        <div class="seo-block">
          <h2 class="display-sm">How to download Twitter/X videos</h2>
          <ol class="seo-steps">
            <li>Find the tweet on Twitter.com or X.com that contains the video.</li>
            <li>Click the <strong>Share</strong> icon → <strong>Copy link to Tweet</strong>.</li>
            <li>Paste the tweet URL in the field above.</li>
            <li>Click <strong>Extract</strong> then <strong>Download MP4</strong>.</li>
          </ol>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">What you can download</h2>
          <ul class="seo-list">
            <li>Twitter/X native videos</li>
            <li>Animated GIFs (converted to MP4)</li>
            <li>Videos from twitter.com and x.com</li>
            <li>Spaces recordings (when public)</li>
          </ul>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Tips</h2>
          <ul class="seo-list">
            <li>Both twitter.com and x.com links work</li>
            <li>Only public tweets can be downloaded</li>
            <li>Protected accounts are not supported</li>
            <li>For personal, non-commercial use only</li>
          </ul>
        </div>
      </div>
    </section>

    <FAQ faqs={twitterFaqs} />
  </main>
  <Footer />
</Layout>

<style>
  .seo-section { padding: var(--sp-4xl) var(--sp-lg); }
  .seo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
  .seo-block { display: flex; flex-direction: column; gap: var(--sp-md); }
  .seo-block h2 { margin: 0; color: var(--color-ink); }
  .seo-steps, .seo-list {
    margin: 0; padding-left: var(--sp-lg);
    display: flex; flex-direction: column; gap: var(--sp-xs);
    color: var(--color-body); font-size: 14px; line-height: 1.7;
  }
</style>

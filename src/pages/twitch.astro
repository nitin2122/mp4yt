---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
const twitchFaqs = [
  {
    q: "How do I download Twitch clips to my phone?",
    a: "Open the Twitch clip URL, click the share icon to copy the link, paste it into our Twitch clip downloader, and click Extract. Save the direct MP4 file to your mobile device."
  },
  {
    q: "Can I download full Twitch VODs (Stream Recordings)?",
    a: "Yes, our Twitch VOD downloader supports both short clips and complete broadcast replays (VODs). Note that extremely long VODs may take slightly longer to fetch links."
  },
  {
    q: "Can I download subscriber-only Twitch VODs?",
    a: "No. Subscriber-only streams or private clips require authentication and are restricted to protect streamer content. Only public Twitch videos can be downloaded."
  }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "mp4yt", "item": "https://mp4yt.com" },
    { "@type": "ListItem", "position": 2, "name": "Twitch Downloader", "item": "https://mp4yt.com/twitch/" }
  ]
};
---

<Layout
  title="Twitch Video Downloader - VODs & Clips | mp4yt"
  description="Download Twitch clips and VODs as MP4 instantly. Paste the Twitch link — no registration, no storage, no limits."
  canonicalUrl="https://mp4yt.com/twitch/"
  keywords="twitch video downloader, twitch clip downloader, download twitch vods, twitch vod downloader, twitch to mp4, best twitch clip downloader 2026"
>
  <Navbar />
  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <PlatformHero
      platform="Twitch"
      emoji="🎮"
      accentColor="#9146FF"
      tagline="Twitch Downloader"
      description="Just Paste and Play."
      placeholder="https://clips.twitch.tv/..."
      features={[
        "Clips & VOD streams",
        "No login required",
        "Fast metadata fetch",
        "Direct CDN download",
        "Zero server storage",
      ]}
    />

    <section class="seo-section page-container">
      <div class="seo-grid">
        <div class="seo-block">
          <h2 class="display-sm">How to download Twitch clips & VODs</h2>
          <ol class="seo-steps">
            <li>Find the Twitch clip or recorded video (VOD) you want to download.</li>
            <li>Copy the URL from the browser's address bar or share icon.</li>
            <li>Paste the URL into the input field above.</li>
            <li>Click <strong>Extract</strong> and download the direct MP4 file.</li>
          </ol>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Twitch features</h2>
          <ul class="seo-list">
            <li>Download short Twitch Clips</li>
            <li>Download full stream broadcasts (VODs)</li>
            <li>Instant CDN streaming bypasses speed limits</li>
            <li>Works on desktop and mobile</li>
          </ul>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Important notes</h2>
          <ul class="seo-list">
            <li>Subscribers-only VODs are not supported</li>
            <li>Only publicly accessible videos can be extracted</li>
            <li>Large VODs might take longer to initialize</li>
            <li>Use downloads for personal archives only</li>
          </ul>
        </div>
      </div>
    </section>

    <FAQ faqs={twitchFaqs} />
  </main>
  <Footer />
</Layout>

<style>
  .seo-section { padding: var(--sp-4xl) var(--sp-lg); }
  .seo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
  .seo-block { display: flex; flex-direction: column; gap: var(--sp-md); }
  .seo-block h2 { margin: 0; color: var(--color-ink); }
  .seo-steps, .seo-list {
    margin: 0; padding-left: var(--sp-lg);
    display: flex; flex-direction: column; gap: var(--sp-xs);
    color: var(--color-body); font-size: 14px; line-height: 1.7;
  }
</style>

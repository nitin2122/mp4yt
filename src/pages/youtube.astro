---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="YouTube Video Downloader — Download YouTube Videos as MP4 | mp4yt"
  description="Download any YouTube video as MP4 instantly. Paste the YouTube URL and get the direct CDN stream — no registration, no storage, no limits."
  canonicalUrl="https://mp4yt.com/youtube"
>
  <Navbar />
  <main id="main-content">
    <PlatformHero
      platform="YouTube"
      emoji="▶️"
      accentColor="#FF0000"
      tagline="Download YouTube videos. Instantly."
      description="Paste any YouTube URL — video, Short, or playlist item — and download the highest quality MP4 in seconds. Powered by yt-dlp."
      placeholder="https://www.youtube.com/watch?v=..."
      features={[
        "HD & 4K quality",
        "YouTube Shorts supported",
        "No registration required",
        "Zero file storage",
        "Instant CDN stream",
      ]}
    />

    <!-- YouTube-specific SEO content -->
    <section class="seo-section page-container">
      <div class="seo-grid">
        <div class="seo-block">
          <h2 class="display-sm">How to download YouTube videos</h2>
          <ol class="seo-steps">
            <li>Go to YouTube and find the video you want to download.</li>
            <li>Copy the video URL from your browser's address bar (or right-click → Copy link address on the YouTube logo).</li>
            <li>Paste it into the input above and click <strong>Extract</strong>.</li>
            <li>Click <strong>Download MP4</strong> — your browser will save the file.</li>
          </ol>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Supported YouTube formats</h2>
          <ul class="seo-list">
            <li>Standard YouTube videos (youtube.com/watch?v=...)</li>
            <li>YouTube Shorts (youtube.com/shorts/...)</li>
            <li>youtu.be short links</li>
            <li>YouTube Music (music.youtube.com)</li>
            <li>YouTube Live replays</li>
          </ul>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Why use mp4yt?</h2>
          <ul class="seo-list">
            <li>No FFmpeg muxing — instant extraction</li>
            <li>No file stored on our servers</li>
            <li>Works on desktop, mobile, and tablet</li>
            <li>Open-source yt-dlp backend</li>
          </ul>
        </div>
      </div>
    </section>

    <FAQ />
  </main>
  <Footer />
</Layout>

<style>
  .seo-section {
    padding: var(--sp-4xl) var(--sp-lg);
  }
  .seo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--sp-xl);
  }
  .seo-block {
    display: flex;
    flex-direction: column;
    gap: var(--sp-md);
  }
  .seo-block h2 {
    margin: 0;
    color: var(--color-ink);
  }
  .seo-steps, .seo-list {
    margin: 0;
    padding-left: var(--sp-lg);
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
    color: var(--color-body);
    font-size: 14px;
    line-height: 1.7;
  }
</style>

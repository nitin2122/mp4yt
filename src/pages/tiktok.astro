---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
const tiktokFaqs = [
  {
    q: "How do I download TikTok videos without a watermark?",
    a: "Paste the TikTok link (Share > Copy Link) into our TikTok downloader. Our system bypasses the standard download mechanism to retrieve a watermark-free high-quality MP4 file."
  },
  {
    q: "Can I convert TikTok video to MP3 audio?",
    a: "Yes. After pasting your TikTok link and clicking Extract, you can select the audio extraction option to save the TikTok sound as a high-quality MP3 file."
  },
  {
    q: "Does the TikTok downloader work on iPhone?",
    a: "Yes. Open Safari on iOS, go to our TikTok video downloader, paste the URL, and extract. You can download and save the file directly to your Files app."
  },
  {
    q: "Does this TikTok downloader save slideshows or photo posts?",
    a: "Yes, our downloader extracts photo slideshows as high-quality images or converts them to video format depending on how the post is shared."
  }
];
---

<Layout
  title="TikTok Video Downloader - No Watermark | mp4yt"
  description="Download TikTok videos as MP4 instantly. Paste the TikTok URL and get a clean download — no watermark via Cobalt, no registration needed."
  canonicalUrl="https://mp4yt.com/tiktok/"
  keywords="tiktok video downloader, download tiktok videos, tiktok downloader no watermark, download tiktok mp4, tiktok mp3, save tiktok video, download tiktok without watermark, tiktok link downloader, tiktok downloader online, tiktok video saver, tiktok to mp4, tiktok downloader free, tiktok downloader hd, download tiktok video online free, tiktok video download without watermark free, snaptik alternative, ssstiktok alternative, download tiktok audio, tiktok sound downloader, tiktok downloader iphone, tiktok downloader android, download tiktok slideshow, tiktok photo downloader, tiktok downloader 2026, best tiktok downloader, tiktok video converter, tiktok repost downloader, download tiktok without app, save tiktok without watermark, tiktok mp4 download hd"
>
  <Navbar />
  <main id="main-content">
    <PlatformHero
      platform="TikTok"
      emoji="🎵"
      accentColor="#69C9D0"
      tagline="TikTok Downloader"
      description="Just Paste and Play."
      placeholder="https://www.tiktok.com/@user/video/..."
      features={[
        "No watermark (when available)",
        "HD quality MP4",
        "No TikTok login",
        "Zero storage",
        "Instant extraction",
      ]}
    />

    <section class="seo-section page-container">
      <div class="seo-grid">
        <div class="seo-block">
          <h2 class="display-sm">How to download TikTok videos</h2>
          <ol class="seo-steps">
            <li>Open TikTok on your phone or browser and find the video.</li>
            <li>Tap <strong>Share → Copy link</strong> or copy the URL from your browser.</li>
            <li>Paste the link in the field above.</li>
            <li>Hit <strong>Extract</strong>, then <strong>Download MP4</strong>.</li>
          </ol>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Supported TikTok links</h2>
          <ul class="seo-list">
            <li>Standard TikTok videos</li>
            <li>TikTok short links (vm.tiktok.com)</li>
            <li>TikTok slideshow/photo posts</li>
            <li>Public profile videos</li>
          </ul>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">About watermarks</h2>
          <ul class="seo-list">
            <li>Cobalt requests the API stream which is often watermark-free</li>
            <li>Results vary by account and region</li>
            <li>Always give credit to the original creator</li>
            <li>For personal use only</li>
          </ul>
        </div>
      </div>
    </section>

    <FAQ faqs={tiktokFaqs} />
  </main>
  <Footer />
</Layout>

<style>
  .seo-section { padding: var(--sp-4xl) var(--sp-lg); }
  .seo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
  .seo-block { display: flex; flex-direction: column; gap: var(--sp-md); }
  .seo-block h2 { margin: 0; color: var(--color-ink); }
  .seo-steps, .seo-list {
    margin: 0; padding-left: var(--sp-lg);
    display: flex; flex-direction: column; gap: var(--sp-xs);
    color: var(--color-body); font-size: 14px; line-height: 1.7;
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Terms of Use — mp4yt"
  description="Terms of Use for mp4yt.com. Review our acceptable use policy, limitations, and disclaimers for the free video download service."
  canonicalUrl="https://mp4yt.com/terms-and-conditions"
>
  <Navbar />
  <main id="main-content">
    <section class="legal-hero">
      <div class="page-container">
        <span class="eyebrow">Legal</span>
        <h1 class="display-xl legal-title">Terms of Use</h1>
        <p class="body-lg legal-subtitle">Last updated: June 2026</p>
      </div>
    </section>

    <section class="legal-body">
      <div class="page-container legal-container">
        <div class="legal-content">

          <h2 class="display-sm">Acceptance of Terms</h2>
          <p>
            By accessing and using mp4yt.com ("the Service"), you agree to be bound by these Terms
            of Use. If you do not agree to these terms, do not use the Service.
          </p>

          <hr class="legal-divider" />

          <h2 class="display-sm">Description of Service</h2>
          <p>
            mp4yt is a free web-based tool that extracts direct video stream URLs from
            supported platforms using the open-source yt-dlp library. The Service does not host,
            store, or re-distribute any video content. It acts solely as a metadata proxy that
            provides the user with the direct CDN URL from the original platform.
          </p>

          <hr class="legal-divider" />

          <h2 class="display-sm">Acceptable Use</h2>
          <p>You agree to use the Service only for:</p>
          <ul>
            <li>Personal, non-commercial use</li>
            <li>Downloading content you have the right to access</li>
            <li>Purposes permitted by applicable copyright law (e.g., fair use, personal backup)</li>
          </ul>
          <p>You agree <strong>not</strong> to:</p>
          <ul>
            <li>Use the Service to infringe on any copyright or intellectual property rights</li>
            <li>Download content for commercial redistribution</li>
            <li>Attempt to circumvent any access controls or DRM protections</li>
            <li>Use automated systems to make bulk or excessive requests</li>
            <li>Use the Service for any unlawful purpose</li>
          </ul>

          <hr class="legal-divider" />

          <h2 class="display-sm">Intellectual Property</h2>
          <p>
            All video content accessed through the Service is the property of the respective content
            creators and platforms. mp4yt does not claim ownership of any third-party content. The
            mp4yt name, logo, and website design are our intellectual property.
          </p>

          <hr class="legal-divider" />

          <h2 class="display-sm">No Warranty</h2>
          <p>
            The Service is provided "as is" and "as available" without warranties of any kind, either
            express or implied. We do not guarantee that:
          </p>
          <ul>
            <li>The Service will be uninterrupted, error-free, or secure</li>
            <li>Any specific video URL will be extractable</li>
            <li>Stream URLs will remain valid beyond their natural expiration</li>
            <li>The Service will be compatible with all platforms or formats</li>
          </ul>

          <hr class="legal-divider" />

          <h2 class="display-sm">Limitation of Liability</h2>
          <p>
            To the maximum extent permitted by law, mp4yt and its operators shall not be liable for any
            indirect, incidental, special, consequential, or punitive damages arising from your use
            of the Service.
          </p>

          <hr class="legal-divider" />

          <h2 class="display-sm">DMCA Compliance</h2>
          <p>
            We respect the intellectual property rights of others. If you believe your copyrighted work
            has been infringed through our Service, please see our
            <a href="/dmca">DMCA Policy</a> for instructions on submitting a takedown notice.
          </p>

          <hr class="legal-divider" />

          <h2 class="display-sm">Changes to These Terms</h2>
          <p>
            We reserve the right to modify these Terms at any time. Changes will be posted on this page.
            Continued use of the Service after changes constitutes acceptance of the new Terms.
          </p>

          <hr class="legal-divider" />

          <h2 class="display-sm">Contact</h2>
          <p>
            For questions about these Terms, contact us at
            <a href="/contact-us">contact us</a>.
          </p>

        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .legal-hero {
    background-color: var(--color-canvas);
    padding: var(--sp-5xl) var(--sp-lg) var(--sp-3xl);
    text-align: center;
  }
  .legal-title {
    margin: var(--sp-sm) 0 0;
    color: var(--color-ink);
  }
  .legal-subtitle {
    margin: var(--sp-xs) 0 0;
    color: var(--color-mute);
  }
  .legal-body {
    background-color: var(--color-canvas-soft);
    padding: var(--sp-4xl) var(--sp-lg);
    border-top: 1px solid var(--color-hairline);
  }
  .legal-container {
    max-width: 720px;
  }
  .legal-content {
    background-color: var(--color-canvas);
    border-radius: var(--rounded-lg);
    padding: var(--sp-xl) var(--sp-xl);
    box-shadow: var(--shadow-3);
  }
  .legal-content h2 {
    margin: var(--sp-xl) 0 var(--sp-md);
    color: var(--color-ink);
  }
  .legal-content h2:first-child {
    margin-top: 0;
  }
  .legal-content p,
  .legal-content li {
    color: var(--color-body);
    font-size: 15px;
    line-height: 1.75;
    margin: 0 0 var(--sp-sm);
  }
  .legal-content ul,
  .legal-content ol {
    padding-left: var(--sp-lg);
    margin: 0 0 var(--sp-md);
  }
  .legal-content li {
    margin-bottom: var(--sp-xs);
  }
  .legal-content a {
    color: var(--color-link);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .legal-content a:hover {
    color: var(--color-link-deep);
    text-decoration: underline;
  }
  .legal-divider {
    border: none;
    border-top: 1px solid var(--color-hairline);
    margin: var(--sp-xl) 0;
  }
  @media (max-width: 768px) {
    .legal-hero { padding: var(--sp-4xl) var(--sp-md) var(--sp-xl); }
    .legal-content { padding: var(--sp-lg); }
  }
</style>

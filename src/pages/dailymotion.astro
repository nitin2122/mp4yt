---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
const dailymotionFaqs = [
  {
    q: "How do I download Dailymotion videos in Full HD?",
    a: "Paste the Dailymotion video URL (or short link dai.ly) into the input box above, click Extract, and select the highest resolution option (such as 1080p) to download the direct MP4 file."
  },
  {
    q: "Is there a limit on the number of Dailymotion video downloads?",
    a: "No. Our Dailymotion downloader is 100% free and has no restrictions on download counts, file size, or conversion speed."
  },
  {
    q: "Does it work with short links like dai.ly?",
    a: "Yes, our Dailymotion link downloader supports both full-length desktop links and mobile-shortened dai.ly sharing links."
  }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "mp4yt", "item": "https://mp4yt.com" },
    { "@type": "ListItem", "position": 2, "name": "Dailymotion Downloader", "item": "https://mp4yt.com/dailymotion/" }
  ]
};
---

<Layout
  title="Dailymotion Downloader - Download Videos | mp4yt"
  description="Download Dailymotion videos in high quality MP4 instantly. Paste the Dailymotion URL — no registration, no storage, no limits."
  canonicalUrl="https://mp4yt.com/dailymotion/"
  keywords="dailymotion video downloader, download dailymotion videos, dailymotion to mp4, dailymotion downloader free, best dailymotion downloader 2026"
>
  <Navbar />
  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <PlatformHero
      platform="Dailymotion"
      emoji="📺"
      accentColor="#003BD8"
      tagline="Dailymotion Downloader"
      description="Just Paste and Play."
      placeholder="https://www.dailymotion.com/video/x..."
      features={[
        "HQ & Full HD quality",
        "No registration required",
        "Direct CDN streaming",
        "Zero server storage",
        "Works on mobile & desktop",
      ]}
    />

    <section class="seo-section page-container">
      <div class="seo-grid">
        <div class="seo-block">
          <h2 class="display-sm">How to download Dailymotion videos</h2>
          <ol class="seo-steps">
            <li>Find the video on Dailymotion you want to save.</li>
            <li>Copy the URL from the browser bar or copy the link from the share options.</li>
            <li>Paste the URL in the text box above.</li>
            <li>Click <strong>Extract</strong> and choose <strong>Download MP4</strong>.</li>
          </ol>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Dailymotion features</h2>
          <ul class="seo-list">
            <li>Works with standard Dailymotion URLs (dailymotion.com/video/...)</li>
            <li>Supports short links (dai.ly/...)</li>
            <li>High resolution video extraction</li>
            <li>Completely free, no hidden costs</li>
          </ul>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Important note</h2>
          <ul class="seo-list">
            <li>Private and password-protected videos are not supported</li>
            <li>For personal, offline archives only</li>
            <li>Zero analytics, no tracking pixels</li>
            <li>Powered by Cobalt</li>
          </ul>
        </div>
      </div>
    </section>

    <FAQ faqs={dailymotionFaqs} />
  </main>
  <Footer />
</Layout>

<style>
  .seo-section { padding: var(--sp-4xl) var(--sp-lg); }
  .seo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
  .seo-block { display: flex; flex-direction: column; gap: var(--sp-md); }
  .seo-block h2 { margin: 0; color: var(--color-ink); }
  .seo-steps, .seo-list {
    margin: 0; padding-left: var(--sp-lg);
    display: flex; flex-direction: column; gap: var(--sp-xs);
    color: var(--color-body); font-size: 14px; line-height: 1.7;
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
const facebookFaqs = [
  {
    q: "How do I download Facebook videos to MP4?",
    a: "To download Facebook videos to MP4, copy the video URL from Facebook (click Share > Copy Link), paste it into our free Facebook downloader, and click Extract. Choose your preferred quality and hit Download."
  },
  {
    q: "Can I download Facebook Reels with this tool?",
    a: "Yes, our FB downloader fully supports Facebook Reels. Simply copy the link to the Reel and paste it here to download the high-quality MP4 video instantly."
  },
  {
    q: "Does the Facebook video downloader work on mobile devices?",
    a: "Absolutely. Our Facebook link downloader is a web-based app that works flawlessly in Safari on iPhone and Chrome/Firefox on Android. No app installation required."
  },
  {
    q: "Can I download private Facebook videos?",
    a: "No. To protect user privacy, our Facebook video downloader only supports public videos and Reels. Videos from private groups or profiles cannot be downloaded."
  }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "mp4yt", "item": "https://mp4yt.com" },
    { "@type": "ListItem", "position": 2, "name": "Facebook Downloader", "item": "https://mp4yt.com/facebook/" }
  ]
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Download Facebook Videos",
  "description": "Step-by-step guide to download Facebook videos and Reels using mp4yt.",
  "totalTime": "PT1M",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Copy the Facebook video URL", "text": "Click Share > Copy Link on the Facebook video or Reel you want to download." },
    { "@type": "HowToStep", "position": 2, "name": "Paste into mp4yt", "text": "Go to mp4yt.com/facebook and paste the copied URL into the extraction bar." },
    { "@type": "HowToStep", "position": 3, "name": "Click Extract", "text": "Click Extract and wait a few seconds for mp4yt to fetch the direct download links." },
    { "@type": "HowToStep", "position": 4, "name": "Download", "text": "Choose your quality and click Download MP4 to save the Facebook video." }
  ]
};
---

<Layout
  title="Facebook Video Downloader - Save FB Videos MP4 | mp4yt"
  description="Download Facebook videos and Reels in high quality MP4 instantly. Paste the Facebook link — no registration, no storage, no limits."
  canonicalUrl="https://mp4yt.com/facebook/"
  keywords="facebook video downloader, download facebook videos, fb downloader, facebook to mp4, facebook reels downloader, fb video download, best facebook video downloader 2026"
>
  <Navbar />
  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <PlatformHero
      platform="Facebook"
      emoji="👥"
      accentColor="#1877F2"
      tagline="Facebook Downloader"
      description="Just Paste and Play."
      placeholder="https://www.facebook.com/watch/?v=..."
      features={[
        "Videos & Reels",
        "No registration",
        "Direct CDN stream",
        "Zero file storage",
        "Mobile friendly",
      ]}
    />

    <section class="seo-section page-container">
      <div class="seo-grid">
        <div class="seo-block">
          <h2 class="display-sm">How to download Facebook videos</h2>
          <ol class="seo-steps">
            <li>Find the Facebook video or Reel you want to download.</li>
            <li>Click <strong>Share</strong> and then <strong>Copy link</strong>.</li>
            <li>Paste the URL into the input box above.</li>
            <li>Click <strong>Extract</strong>, wait for preview, and click <strong>Download MP4</strong>.</li>
          </ol>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Facebook features</h2>
          <ul class="seo-list">
            <li>Facebook Reels support</li>
            <li>Watch/Page videos</li>
            <li>Group video links (public)</li>
            <li>Mobile and desktop access</li>
          </ul>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Limitations</h2>
          <ul class="seo-list">
            <li>Only public Facebook videos are supported</li>
            <li>Private groups/profiles cannot be downloaded</li>
            <li>We do not store your download history</li>
            <li>Ensure respect for creator copyright</li>
          </ul>
        </div>
      </div>
    </section>

    <FAQ faqs={facebookFaqs} />
  </main>
  <Footer />
</Layout>

<style>
  .seo-section { padding: var(--sp-4xl) var(--sp-lg); }
  .seo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
  .seo-block { display: flex; flex-direction: column; gap: var(--sp-md); }
  .seo-block h2 { margin: 0; color: var(--color-ink); }
  .seo-steps, .seo-list {
    margin: 0; padding-left: var(--sp-lg);
    display: flex; flex-direction: column; gap: var(--sp-xs);
    color: var(--color-body); font-size: 14px; line-height: 1.7;
  }
</style>

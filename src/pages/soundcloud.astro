---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
const soundcloudFaqs = [
  {
    q: "How do I download SoundCloud songs to MP3?",
    a: "Copy the SoundCloud track URL, paste it into our SoundCloud downloader, and click Extract. The downloader fetches the audio and saves it as a high-quality MP3 file."
  },
  {
    q: "What audio quality does the SoundCloud downloader provide?",
    a: "We extract the highest quality audio stream available directly from SoundCloud's CDN (usually 128kbps or 256kbps depending on uploader settings and track type)."
  },
  {
    q: "Can I download full SoundCloud playlists?",
    a: "We currently support downloading tracks individually. To save playlist songs, copy and extract each track link separately."
  }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "mp4yt", "item": "https://mp4yt.com" },
    { "@type": "ListItem", "position": 2, "name": "SoundCloud Downloader", "item": "https://mp4yt.com/soundcloud/" }
  ]
};
---

<Layout
  title="SoundCloud Downloader - MP3 & MP4 Free | mp4yt"
  description="Download SoundCloud tracks and audio files instantly. Paste the SoundCloud URL — no registration, no storage, no limitations."
  canonicalUrl="https://mp4yt.com/soundcloud/"
  keywords="soundcloud downloader, soundcloud to mp3, download soundcloud songs, soundcloud mp3 downloader, best soundcloud downloader 2026"
>
  <Navbar />
  <main id="main-content">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <PlatformHero
      platform="SoundCloud"
      emoji="🎵"
      accentColor="#FF5500"
      tagline="SoundCloud Downloader"
      description="Just Paste and Play."
      placeholder="https://soundcloud.com/username/track-name"
      features={[
        "HQ Audio extraction",
        "No registration required",
        "Fast metadata lookup",
        "Direct CDN stream URL",
        "Zero server storage",
      ]}
    />

    <section class="seo-section page-container">
      <div class="seo-grid">
        <div class="seo-block">
          <h2 class="display-sm">How to download SoundCloud songs</h2>
          <ol class="seo-steps">
            <li>Find the track on SoundCloud you want to download.</li>
            <li>Copy the track's URL from your address bar or click the share button.</li>
            <li>Paste the track link into the input bar above.</li>
            <li>Click <strong>Extract</strong> and download your audio file.</li>
          </ol>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">SoundCloud extraction details</h2>
          <ul class="seo-list">
            <li>Extracts original streaming quality</li>
            <li>Works for individual tracks</li>
            <li>No browser extensions required</li>
            <li>Works on mobile phones and tablets</li>
          </ul>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Important note</h2>
          <ul class="seo-list">
            <li>Copyrighted files should only be saved for personal/offline listening</li>
            <li>Private playlists and sets are not supported</li>
            <li>We do not store or mirror SoundCloud audio</li>
            <li>Free to use, always</li>
          </ul>
        </div>
      </div>
    </section>

    <FAQ faqs={soundcloudFaqs} />
  </main>
  <Footer />
</Layout>

<style>
  .seo-section { padding: var(--sp-4xl) var(--sp-lg); }
  .seo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
  .seo-block { display: flex; flex-direction: column; gap: var(--sp-md); }
  .seo-block h2 { margin: 0; color: var(--color-ink); }
  .seo-steps, .seo-list {
    margin: 0; padding-left: var(--sp-lg);
    display: flex; flex-direction: column; gap: var(--sp-xs);
    color: var(--color-body); font-size: 14px; line-height: 1.7;
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found (404) — mp4yt"
  description="The page you are looking for does not exist or has been moved. Return to mp4yt homepage to download videos from YouTube, TikTok, Instagram & more."
  canonicalUrl="https://mp4yt.com"
  noindex={true}
>
  <Navbar />
  <main id="main-content">
    <section class="error-section">
      <div class="page-container error-content">
        <span class="error-code">404</span>
        <span class="error-eyebrow">ERROR_NOT_FOUND</span>
        <h1 class="display-xl error-title">
          LOST IN TRANSIT.
        </h1>
        <p class="body-md error-subtitle">
          We couldn't find the page you were looking for. The link might be broken, or the page has moved.
        </p>
        <div class="error-actions">
          <a href="/" class="btn-primary btn-primary-lg">
            BACK TO HOMEPAGE
          </a>
          <a href="/contact-us" class="btn-secondary" style="height: 48px;">
            CONTACT SUPPORT
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .error-section {
    position: relative;
    background-color: var(--color-canvas);
    border-bottom: var(--border);
    min-height: calc(100vh - 64px - 280px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-section) var(--sp-lg);
    text-align: center;
  }

  .error-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-md);
    max-width: 600px;
  }

  .error-code {
    font-family: var(--font-headline);
    font-size: 120px;
    font-weight: 800;
    line-height: 1;
    color: var(--color-canvas-soft-2);
    letter-spacing: -0.05em;
  }

  .error-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-on-primary);
    background-color: var(--color-error);
    padding: 4px 12px;
    border: var(--border);
  }

  .error-title {
    margin: 0;
    color: var(--color-ink);
  }

  .error-subtitle {
    margin: 0;
    color: var(--color-body);
    line-height: 1.6;
  }

  .error-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-md);
    margin-top: var(--sp-lg);
    width: 100%;
  }

  @media (max-width: 600px) {
    .error-section {
      min-height: calc(100vh - 64px - 400px);
      padding: var(--sp-4xl) var(--sp-md);
    }
    .error-code { font-size: 80px; }
    .error-actions {
      flex-direction: column;
      gap: var(--sp-sm);
    }
    .error-actions a {
      width: 100%;
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
const instagramFaqs = [
  {
    q: "How do I use the Instagram reels downloader?",
    a: "To download Instagram Reels, copy the Reel link from the Instagram app (Share > Copy Link), paste it into the search box on our Instagram downloader page, click Extract, and download it as a high-quality MP4."
  },
  {
    q: "Do I need to log in to my Instagram account to download videos?",
    a: "No login or registration is required. Our Instagram video downloader works completely anonymously without needing your IG username or password."
  },
  {
    q: "Can I save Instagram Stories or IGTV videos?",
    a: "Yes, our universal Instagram saver can extract public Stories, IGTV videos, and feed posts. Make sure the target profile is set to public."
  },
  {
    q: "Where do my downloaded Instagram videos get saved?",
    a: "Downloaded files are saved directly to your device's default downloads folder (e.g., Downloads on Android/PC or the Files app/Safari downloads on iOS)."
  }
];
---

<Layout
  title="Instagram Video Downloader - Reels & MP4 | mp4yt"
  description="Download Instagram Reels, videos, and Stories as MP4 instantly. Paste the Instagram URL — no login, no storage, no limits."
  canonicalUrl="https://mp4yt.com/instagram/"
  keywords="instagram video downloader, instagram reels downloader, download instagram reels, download instagram video, ig video downloader, ig reels downloader, instagram video saver, save instagram video, instagram link downloader, instagram to mp4, download instagram reels mp4, instagram video download online, download ig stories, instagram story downloader, igtv downloader, download igtv videos, instagram downloader free, instagram downloader no login, insta video downloader, instagram reels download online free, download instagram video on iphone, instagram video downloader android, instagram downloader hd, instagram reel saver, download instagram reels without watermark, insta reels download, instagram private video downloader, instagram downloader 2026, save ig reels, download reels from instagram online"
>
  <Navbar />
  <main id="main-content">
    <PlatformHero
      platform="Instagram"
      emoji="📸"
      accentColor="#E1306C"
      tagline="Instagram Downloader"
      description="Just Paste and Play."
      placeholder="https://www.instagram.com/reel/..."
      features={[
        "Reels & Videos",
        "No Instagram login",
        "High quality MP4",
        "Zero storage",
        "Works on mobile",
      ]}
    />

    <section class="seo-section page-container">
      <div class="seo-grid">
        <div class="seo-block">
          <h2 class="display-sm">How to download Instagram Reels</h2>
          <ol class="seo-steps">
            <li>Open the Instagram app or website and find the Reel or video.</li>
            <li>Tap the three-dot menu → <strong>Copy link</strong> (mobile) or copy the URL from your browser.</li>
            <li>Paste the link into the input field above.</li>
            <li>Click <strong>Extract</strong> then <strong>Download MP4</strong>.</li>
          </ol>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">What you can download</h2>
          <ul class="seo-list">
            <li>Instagram Reels</li>
            <li>Instagram Feed videos</li>
            <li>IGTV videos</li>
            <li>Public profile videos</li>
          </ul>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Important notes</h2>
          <ul class="seo-list">
            <li>Only public content can be downloaded</li>
            <li>Private profiles are not supported</li>
            <li>Stories require public accounts</li>
            <li>For personal use only</li>
          </ul>
        </div>
      </div>
    </section>

    <FAQ faqs={instagramFaqs} />
  </main>
  <Footer />
</Layout>

<style>
  .seo-section { padding: var(--sp-4xl) var(--sp-lg); }
  .seo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
  .seo-block { display: flex; flex-direction: column; gap: var(--sp-md); }
  .seo-block h2 { margin: 0; color: var(--color-ink); }
  .seo-steps, .seo-list {
    margin: 0; padding-left: var(--sp-lg);
    display: flex; flex-direction: column; gap: var(--sp-xs);
    color: var(--color-body); font-size: 14px; line-height: 1.7;
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlatformHero from '../components/PlatformHero.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
const linkedinFaqs = [
  {
    q: "How do I download a video from a LinkedIn post?",
    a: "Click the three dots on the top-right of the LinkedIn post, choose 'Copy link to post', paste it into our LinkedIn video downloader, and click Extract to download the MP4 file."
  },
  {
    q: "Do I need to be logged into LinkedIn to use the downloader?",
    a: "No, you do not need a LinkedIn account. Our tool fetches the public video feed from the post link completely anonymously."
  },
  {
    q: "Can I download videos from private LinkedIn groups or direct messages?",
    a: "No. Our downloader can only retrieve videos from public posts and feeds. Group-locked or message-locked videos are secure and cannot be fetched."
  }
];
---

<Layout
  title="LinkedIn Video Downloader - Save Videos as MP4 | mp4yt"
  description="Download LinkedIn videos in high quality MP4 instantly. Paste the LinkedIn video URL — no login, no storage, no limits."
  canonicalUrl="https://mp4yt.com/linkedin/"
  keywords="linkedin video downloader, download linkedin videos, save linkedin video, linkedin post downloader, download linkedin mp4, linkedin link downloader, linkedin video download online, linkedin video saver, download video from linkedin, linkedin downloader free, linkedin video downloader hd, linkedin mp4 downloader, download linkedin video post, linkedin video download iphone, linkedin video downloader android, best linkedin video downloader, linkedin video converter, linkedin downloader no login, save linkedin post video, download linkedin feed video, linkedin video download 2026, linkedin video download online free, download linkedin video to phone, linkedin video saver online, linkedin content downloader"
>
  <Navbar />
  <main id="main-content">
    <PlatformHero
      platform="LinkedIn"
      emoji="👔"
      accentColor="#0A66C2"
      tagline="LinkedIn Downloader"
      description="Just Paste and Play."
      placeholder="https://www.linkedin.com/posts/..."
      features={[
        "LinkedIn video posts",
        "No login required",
        "Direct CDN download",
        "Zero server storage",
        "Mobile friendly",
      ]}
    />

    <section class="seo-section page-container">
      <div class="seo-grid">
        <div class="seo-block">
          <h2 class="display-sm">How to download LinkedIn videos</h2>
          <ol class="seo-steps">
            <li>Find the LinkedIn post containing the video you want to download.</li>
            <li>Click the three dots in the top right of the post → select <strong>Copy link to post</strong>.</li>
            <li>Paste the URL in the downloader box above.</li>
            <li>Click <strong>Extract</strong>, review preview, and select <strong>Download MP4</strong>.</li>
          </ol>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Supported formats</h2>
          <ul class="seo-list">
            <li>Standard LinkedIn video posts (linkedin.com/posts/...)</li>
            <li>Feed videos & professional clips</li>
            <li>High resolution MP4 downloads</li>
            <li>Direct fast CDNs</li>
          </ul>
        </div>
        <div class="seo-block">
          <h2 class="display-sm">Disclaimer</h2>
          <ul class="seo-list">
            <li>Private posts and direct messages are not supported</li>
            <li>Personal archival use only</li>
            <li>Zero analytics, no tracking pixels</li>
            <li>Bypass browser restrictions with our proxy</li>
          </ul>
        </div>
      </div>
    </section>

    <FAQ faqs={linkedinFaqs} />
  </main>
  <Footer />
</Layout>

<style>
  .seo-section { padding: var(--sp-4xl) var(--sp-lg); }
  .seo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
  .seo-block { display: flex; flex-direction: column; gap: var(--sp-md); }
  .seo-block h2 { margin: 0; color: var(--color-ink); }
  .seo-steps, .seo-list {
    margin: 0; padding-left: var(--sp-lg);
    display: flex; flex-direction: column; gap: var(--sp-xs);
    color: var(--color-body); font-size: 14px; line-height: 1.7;
  }
</style>

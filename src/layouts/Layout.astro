---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogTitle?: string;
  canonicalUrl?: string;
  keywords?: string;
  noindex?: boolean;
}

const {
  title = 'mp4yt — YT Video Downloader | Download Any Video Instantly',
  description = 'Free YT video downloader — download YouTube, Instagram, TikTok, Twitter and 1000+ site videos as MP4 instantly. Zero storage, zero tracking.',
  ogImage = '/og-default.png',
  ogTitle = title,
  canonicalUrl = 'https://mp4yt.com/',
  keywords = 'yt downloader, yt video downloader, download yt video, yt to mp4, yt to mp3, video downloader, online video downloader, free video downloader, video downloader online free, mp4 video downloader, download video from any website, download video online, save video from url, best video downloader 2026, video downloader no watermark, video downloader hd, video downloader 4k, video downloader mp3, video downloader for pc, video downloader for iphone, video downloader for android, video downloader app free, fast video downloader, safe video downloader, video downloader no app, social media video downloader, all in one video downloader, download youtube videos, download tiktok videos, download instagram reels, url to mp4 converter, video link downloader, paste link download video',
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Consent Mode v2 Setup -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      
      const storedConsent = localStorage.getItem('cookie-consent');
      if (storedConsent === 'granted') {
        gtag('consent', 'default', {
          'ad_storage': 'granted',
          'ad_user_data': 'granted',
          'ad_personalization': 'granted',
          'analytics_storage': 'granted'
        });
      } else {
        gtag('consent', 'default', {
          'ad_storage': 'denied',
          'ad_user_data': 'denied',
          'ad_personalization': 'denied',
          'analytics_storage': 'denied'
        });
      }
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-LNH5RT5R2G" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-LNH5RT5R2G');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    {!noindex && <link rel="canonical" href={canonicalUrl} />}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Mp4yt" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="mp4yt" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@mp4yt" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Theme: FOUC prevention — must run before paint -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem('theme');
        if (t === 'dark' || t === 'light') {
          document.documentElement.setAttribute('data-theme', t);
        }
      })();
    </script>

    <!-- Robots & Indexing -->
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f9f9f9" media="(prefers-color-scheme: light)" />

    <!-- Structured Data (JSON-LD) — WebApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "mp4yt",
      "alternateName": ["YT Downloader", "YT Video Downloader", "YouTube Video Downloader", "yt downloader online"],
      "url": "https://mp4yt.com",
      "description": description,
      "applicationCategory": "MultimediaApplication",
      "operatingSystem": "Web, Android, iOS, Windows, macOS, Linux",
      "browserRequirements": "Requires a modern web browser",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "featureList": ["Download YT videos in 4K", "Convert YT to MP3", "YT to MP4 converter", "No app installation needed", "Works on iPhone, Android, PC", "1000+ supported platforms"]
    })} />

    <!-- Structured Data (JSON-LD) — SoftwareApplication for exact-match -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "YT Video Downloader - mp4yt",
      "alternateName": ["YT Downloader", "YouTube Downloader"],
      "url": "https://mp4yt.com",
      "description": "Free YT video downloader online. Download yt videos in 4K MP4 or convert to MP3. Best yt downloader 2026 — no app needed.",
      "applicationCategory": "MultimediaApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    })} />

    <!-- Structured Data (JSON-LD) — BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "YT Video Downloader",
          "item": "https://mp4yt.com"
        }
      ]
    })} />

  </head>
  <body>
    <slot />
    <CookieConsent />

    <!-- GSAP + ScrollTrigger — deferred to avoid blocking first paint (~35KB gzip) -->
    <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js" defer is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js" defer is:inline></script>

    <script is:inline>
      (function() {
        // Skip SW registration for search engine renderers (Googlebot WRS rejects .register())
        if (/googlebot|google-inspectiontool|bingbot|yandex/i.test(navigator.userAgent)) return;
        if (!('serviceWorker' in navigator)) return;
        try {
          window.addEventListener('load', function() {
            try {
              navigator.serviceWorker.register('/sw.js')
                .then(function(reg) {
                  console.log('[mp4yt] SW registered:', reg.scope);
                })
                .catch(function() { /* silent — expected in some environments */ });
            } catch (e) { /* silent */ }
          });
        } catch (e) { /* silent */ }
      })();
    </script>
  </body>
</html>

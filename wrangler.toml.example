# wrangler.toml.example
# Copy this file to wrangler.toml and fill in your values.
# NEVER commit wrangler.toml — it is gitignored.

name = "mp4yt"
main = "worker.js"
compatibility_date = "2024-04-03"

[build]
command = "npm run build"

[assets]
directory = "./dist"
binding = "ASSETS"
run_worker_first = true

[vars]
# Comma-separated list of open Cobalt API instances for failover.
# Find open instances at https://cobalt.directory/
COBALT_FALLBACK_INSTANCES = ""

# Optional: Your self-hosted Cobalt instance URL (highest priority).
# Set this via Cloudflare dashboard → Workers → Settings → Variables
# for production. Only use here for local development.
# COBALT_API_URL = ""

[triggers]
crons = ["*/5 * * * *"]
